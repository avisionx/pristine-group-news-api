{"updated_at": {"date": {"d": "04", "m": "06", "Y": "2026"}, "time": {"H": "08", "M": "09", "S": "39"}}, "news": [{"title": "Uttar Pradesh government to draft GIS-based master plans for 93 tier-II towns across 49 districts", "para": "Uttar Pradesh is preparing GIS-based master plans for 93 tier II towns with populations between 50,000 and 1 lakh to ensure planned development. This initiative aims to detail land usage and future projects for government agencies and stakeholders, addressing a gap in regulatory oversight for many of these urban local bodies.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/uttar-pradesh-launches-gis-based-master-plans-for-93-tier-ii-towns-to-ensure-planned-development/131496328?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-23260/131496328.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Property tax defaulters in Chandigarh to soon get recovery notices", "para": "Chandigarh civic body is preparing to send recovery notices to approximately 70,000-75,000 property tax defaulters. These notices will include penalties and interest on unpaid taxes. Residential property defaulters are identified as the majority. Stern actions, including property sealing for commercial defaulters and water supply disconnection for residential defaulters, will be taken if taxes remain unpaid.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/chandigarh-to-ramp-up-recovery-notices-for-property-tax-defaulters/131496208?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-41194/131496208.cms?width=150&height=112", "tag": "regulatory"}, {"title": "MCG faces property ID backlog after reshuffle of clerks in Gurugram, 77% files stuck", "para": "Gurugram's property tax branch is struggling with a large backlog of property objections and new ID applications. This follows a recent reshuffle of clerks amid corruption allegations. Many applications are stuck at the MCG level, delaying essential property transactions. Officials cite the transfers and census duties for the delay. They promise daily follow-ups to resolve the pending issues soon.", "href": "https://realty.economictimes.indiatimes.com/news/industry/mcgs-property-id-backlog-surges-to-3907-after-clerks-reshuffle/131496091?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-67842/131496091.cms?width=150&height=112", "tag": "industry"}, {"title": "Over 5,000 applications to be clear under Majhe Ghar scheme: Goa CM", "para": "Goa Chief Minister Pramod Sawant announced over 5,000 Majhe Ghar scheme applications approved, with 3,000 orders ready for handover. He emphasized the government's commitment to preventing illegal construction, particularly by migrants, and streamlining processes for house regularisation on government and comunidade land.", "href": "https://realty.economictimes.indiatimes.com/news/residential/goas-majhe-ghar-scheme-sees-over-5000-applications-approved-cm-pramod-sawant/131495925?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-142306/131495925.cms?width=150&height=112", "tag": "residential"}, {"title": "Telangana government to revise property registration rates from June 5", "para": "Telangana is set to implement revised property registration values from June 5, the first major update in nearly a year. The revisions, ranging from 25% to 100% increases, aim to align government-notified rates with actual market values, particularly in urban core areas. This move follows extensive surveys and aims to bridge a significant gap identified between official and market prices.", "href": "https://realty.economictimes.indiatimes.com/news/residential/telangana-announces-major-property-registration-rate-overhaul-effective-june-5/131495806?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-36876/131495806.cms?width=150&height=112", "tag": "residential"}, {"title": "Himachal Pradesh land pooling policy to be in line with successful models adopted by other states", "para": "Himachal Pradesh is set to implement a Land Pooling Policy, drawing inspiration from successful models in states like Punjab. This initiative aims to alleviate congestion in Shimla and other key areas by exploring new township developments and relocating wholesale markets. The government is also focusing on improving traffic flow in Shimla by addressing major bottlenecks and enhancing parking facilities.", "href": "https://realty.economictimes.indiatimes.com/news/industry/himachal-pradesh-introduces-land-pooling-policy-inspired-by-successful-state-models/131495730?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1689478/131495730.cms?width=150&height=112", "tag": "industry"}, {"title": "Delhi to withdraw B&B policy after Malviya Nagar fire tragedy: Tourism minister", "para": "Following a devastating fire that killed 21 people, the Delhi government is withdrawing its Bed and Breakfast policy and reviewing all licensed establishments. The Flourish Stay B&B, allegedly operating with 25 rooms despite a six-room license and lacking fire safety clearance, is at the center of the probe. This incident highlights systemic issues in regulatory oversight and enforcement.", "href": "https://realty.economictimes.indiatimes.com/news/hospitality/delhi-to-withdraw-bed-breakfast-policy-following-malviya-nagar-fire-tragedy/131495613?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-24142/131495613.cms?width=150&height=112", "tag": "hospitality"}, {"title": "Uttar Pradesh cabinet approves funds for new city development in Agra, Bareilly, Prayagraj", "para": "Uttar Pradesh Cabinet approved funds for new city development in Agra, Bareilly, and Prayagraj. The Chief Minister Urban Expansion/New City Promotion Scheme will receive Rs 3,500 crore for the financial year 2026-27. Seed capital of Rs 355.06 crore is approved for these projects.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/uttar-pradesh-approves-rs-3500-crore-for-new-urban-development-in-agra-bareilly-and-prayagraj/131495360?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1777493/131495360.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Delhi: MCD to seal unauthorised commercial buildings in South Zone after Malviya Nagar blaze", "para": "Following a fatal fire that killed 21 people, the Municipal Corporation of Delhi will begin sealing unauthorized commercial buildings in the South Zone. The bed-and-breakfast hotel, located in a Lal Dora village area, operated with 25 rooms despite permission for only six and lacked a sanctioned building plan.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/mcd-to-seal-unauthorized-commercial-buildings-after-malviya-nagar-fire-tragedy/131495335?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-54880/131495335.cms?width=150&height=112", "tag": "commercial"}, {"title": "Delhi home minister says buildings lacking fire safety NOC, other approvals to be sealed", "para": "Following a fatal fire in Malviya Nagar, Delhi Home Minister Ashish Sood announced that all buildings lacking required fire safety and other permissions will be sealed. An immediate city-wide enforcement drive and a crackdown on illegal hotels have been ordered. The tragedy highlighted serious violations at a B&B establishment, prompting a comprehensive inspection of similar facilities.", "href": "https://realty.economictimes.indiatimes.com/news/industry/delhi-government-to-seal-buildings-lacking-fire-safety-approvals-post-malviya-nagar-fire/131495278?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-81860/131495278.cms?width=150&height=112", "tag": "industry"}, {"title": "Insomniacs and YoUnique Communication launches YouBeYou", "para": "Insomniacs and YoUnique Communication have launched YouBeYou, a new integrated communications ecosystem for India's real estate and infrastructure brands. This venture combines Insomniacs' digital marketing and tech expertise with YoUnique's PR and brand storytelling strengths. YouBeYou aims to offer a unified approach to enhance brand visibility, credibility, and long-term reputation for the sector.", "href": "https://realty.economictimes.indiatimes.com/news/brand-connect-initiative/youbeyou-new-integrated-communications-ecosystem-for-real-estate-and-infrastructure-launched-by-insomniacs-and-younique-communication/131485775?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-2923553/131485775.cms?width=150&height=112", "tag": "brand-connect-initiative"}, {"title": "Propsoch raises $2 million in seed funding", "para": "Bengaluru-based Propsoch has secured USD 2 million in seed funding, with Athera Venture Partners, Sparrow Capital, and Vakil Group leading the round. This capital infusion will bolster research and advisory services, team expansion, and market growth. The company previously raised USD 600,000 in pre-seed funding.", "href": "https://realty.economictimes.indiatimes.com/news/startups/propsoch-raises-2-million-in-seed-funding/131480289?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-31696/131480289.cms?width=150&height=112", "tag": "startups"}, {"title": "SC sets up expert panel on Aravalis, petitioners question its independence", "para": "The Supreme Court has formed a five-member high-powered committee to redefine the 'Aravali hills and ranges', dropping the controversial 100m height criterion. This committee will assess the ecological impact of regulated mining and identify areas excluded from protection, aiming to prevent further degradation of the ancient mountain ranges.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/supreme-court-establishes-expert-panel-to-redefine-aravali-hills-amid-concerns/131479592?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-69118/131479592.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Indore district records doubling of housing stock over 15 years", "para": "Indore district has seen a substantial rise in homes and people over the last fifteen years. The initial census phase shows housing units more than doubling. Population figures have also climbed significantly. This growth is evident in both urban and rural areas. The second phase of the census will confirm final population numbers.", "href": "https://realty.economictimes.indiatimes.com/news/residential/housing-stock-in-indore-district-doubles-over-15-years-to-meet-growing-population/131479553?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-19542/131479553.cms?width=150&height=112", "tag": "residential"}, {"title": "Rajasthan lifts cap on building height, set to embrace skyscrapers", "para": "Rajasthan is set to witness the rise of skyscrapers, with the state government removing the 70-meter height cap on buildings. This move, following a central government regulation, will allow for vertical development of commercial towers, schools, and hospitals. Buildings will now be permitted to extend to any height, provided they meet advanced firefighting system standards as per NBCS 2026.", "href": "https://realty.economictimes.indiatimes.com/news/industry/rajasthan-embraces-skyscrapers-new-building-height-regulations-lift-limitations/131475497?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-29210/131475497.cms?width=150&height=112", "tag": "industry"}, {"title": "Rents hit new highs around Hyderabad IT hubs", "para": "Soaring house rentals in Hyderabad's IT corridor are forcing professionals into shared accommodations and longer commutes. Rents for 1BHK and 2BHK apartments have significantly increased, pushing many to seek more affordable options further away from their workplaces. This trend impacts newcomers and mid-level employees the most, creating a difficult balance between cost and convenience.", "href": "https://realty.economictimes.indiatimes.com/news/residential/rents-hit-new-highs-around-hyderabad-it-hubs/131475415?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-19682/131475415.cms?width=150&height=112", "tag": "residential"}, {"title": "British Land names Joanne McNamara as CEO", "para": "British Land Company has appointed Joanne McNamara as its new chief executive officer, succeeding Simon Carter. McNamara, currently executive vice president of European business at Oxford Properties, brings extensive real estate expertise and a strong reputation for leadership. Her appointment comes as the company reported strong annual profits, driven by demand for office spaces from AI and tech firms.", "href": "https://realty.economictimes.indiatimes.com/news/international/joanne-mcnamara-appointed-ceo-of-british-land-company-amid-leadership-change/131475212?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-25196/131475212.cms?width=150&height=112", "tag": "international"}, {"title": "Delhi CM directs MCD to identify unauthorised, illegal building constructions after Saket incident", "para": "Following a fatal building collapse in Saket, Chief Minister Rekha Gupta has ordered the MCD to conduct a comprehensive survey of unauthorized constructions across Delhi. The directive aims to identify irregularities and ensure strict action against those responsible for violations of safety norms and administrative negligence.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/delhi-cm-orders-mcd-to-crack-down-on-illegal-constructions-after-saket-building-collapse/131475037?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-34452/131475037.cms?width=150&height=112", "tag": "infrastructure"}]}
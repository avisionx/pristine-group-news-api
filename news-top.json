{"updated_at": {"date": {"d": "21", "m": "03", "Y": "2026"}, "time": {"H": "12", "M": "23", "S": "53"}}, "news": [{"title": "Jaipur's draft master plan 2047 lacks central government's guidelines: Experts", "para": "A new study reveals significant flaws in Jaipur's Master Plan 2047, suggesting its proposed expansion violates URDPFI guidelines. Experts warn the plan's inclusion of vast rural areas and excessive urbanizable land could severely impact civic services and infrastructure quality for residents.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/jaipurs-master-plan-2047-glaring-flaws-in-urban-planning-exposed-by-experts/129711989?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-18692/129711989.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "ED attaches fresh \u20b95,000 crore assets in case against PACL", "para": "The Enforcement Directorate has attached properties valued at over Rs 5,000 crore. This action is part of a money laundering probe into the PACL ponzi scheme. The scheme allegedly defrauded lakhs of investors of approximately Rs 48,000 crore. This latest attachment brings the total seized assets to over Rs 22,000 crore. The investigation stems from a 2014 CBI case.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ed-attaches-fresh-5000-crore-assets-in-case-against-pacl/129711981?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-543062/129711981.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Delhi: Get provisional NOC for house by paying 25% of infrastructure charges upfront", "para": "Delhi Jal Board has approved a significant reform in infrastructure charge payments, allowing property owners to obtain a provisional NOC by paying 25% upfront during building plan approval. This move aims to unlock stalled projects and ease financial burdens, with the remaining charges adjusted later based on final rates.", "href": "https://realty.economictimes.indiatimes.com/news/residential/delhi-government-offers-relief-pay-25-of-infrastructure-charges-for-provisional-noc/129711960?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-27200/129711960.cms?width=150&height=112", "tag": "residential"}]}
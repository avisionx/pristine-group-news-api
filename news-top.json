{"updated_at": {"date": {"d": "11", "m": "05", "Y": "2026"}, "time": {"H": "12", "M": "33", "S": "00"}}, "news": [{"title": "Micro Mitti launches information technology park on 2.3 acres land in Indore", "para": "Micro Mitti has launched its IT park, Cybercity, in Indore, Madhya Pradesh, spanning 2.30 acres with 6.28 lakh sq ft of built-up area. The project will offer 77 office and 13 retail units, focusing on leasing with a total leasable area of 4.48 lakh sq ft.  Investment stands at \u20b9300 crore, with completion anticipated by 2029.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/micro-mitti-unveils-cybercity-it-park-a-new-horizon-for-indores-technology-landscape/131008868?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-134782/131008868.cms?width=150&height=112", "tag": "commercial"}, {"title": "Court upholds Nagpur civic body's eviction drive on prime Subhash Road land", "para": "A district court has upheld the Nagpur Municipal Corporation's eviction of illegal occupants from a prime 15,000 sq m land parcel. The lease, granted in 1937 to Abhyankar Smarak Trust, expired in 1967 and was never renewed.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/nagpur-court-rules-in-favor-of-civic-bodys-eviction-drive-on-prime-land/131007236?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-26418/131007236.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Dwarka projects to earn Delhi development body \u20b929,000 crore in licence fees", "para": "Delhi Development Authority is shifting to long-term land leasing, expecting over Rs 29,700 crore from three Dwarka projects over 55 years. A five-star hotel, a Transit Oriented Development, and a super-speciality hospital will generate substantial annual licence fees, boosting infrastructure and DDA's revenue streams.", "href": "https://realty.economictimes.indiatimes.com/news/industry/delhi-development-authority-set-to-earn-29700-crore-from-groundbreaking-dwarka-projects/131007301?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-73438/131007301.cms?width=150&height=112", "tag": "industry"}]}
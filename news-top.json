{"updated_at": {"date": {"d": "31", "m": "03", "Y": "2026"}, "time": {"H": "08", "M": "44", "S": "20"}}, "news": [{"title": "Premium hotels pay UD tax after Jaipur civic body seals properties", "para": "Jaipur Municipal Corporation sealed properties of Hotel Marriott and Hotel Ramada for outstanding urban development tax. Following the action, both hotel managements cleared their dues, amounting to Rs 5 crore and Rs 1 crore respectively, leading to the unsealing of their properties within two hours.", "href": "https://realty.economictimes.indiatimes.com/news/hospitality/jaipur-hotels-pay-ud-tax-after-sealing-immediate-compliance-shown/129915063?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-54150/129915063.cms?width=150&height=112", "tag": "hospitality"}, {"title": "In a first, Ranchi civic body collects \u20b9108 crore in taxes", "para": "Ranchi Municipal Corporation has achieved a record Rs 108 crore in tax collection this financial year, with property tax contributing a significant Rs 100 crore. This surge, attributed to intensified drives and digital payment systems, will fund civic infrastructure improvements. Traders note the convenience of online payment systems has boosted compliance.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ranchi-municipal-corporation-achieves-historic-108-crore-tax-collection/129915052?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-108238/129915052.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Belagavi civic body revises property tax rates starting April 1", "para": "Belagavi City Corporation has revised property tax rates, increasing them by 3% for residential properties and 4% for commercial, industrial, and plots, effective April 1. This move aims to boost annual revenue by Rs 2-3 crore, with a 5% discount offered for early payment.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/belagavi-increases-property-tax-rates-new-revenue-plans-announced/129915014?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-85598/129915014.cms?width=150&height=112", "tag": "regulatory"}]}
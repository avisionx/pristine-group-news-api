{"updated_at": {"date": {"d": "06", "m": "06", "Y": "2026"}, "time": {"H": "11", "M": "14", "S": "18"}}, "news": [{"title": "Delhi HC impleads JK Paper as defendant in the legal dispute over Prithviraj Road bungalow", "para": "JK Paper Ltd is now a defendant in a Delhi High Court case. The dispute concerns a bungalow on Prithviraj Road. Punit Beriwala claims he made an advance payment for the property in 2004. JK Paper acquired the bungalow in December 2021 for Rs 250 crore. Beriwala's counsel informed JK Paper about his client's claim.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/delhi-high-court-adds-jk-paper-to-dispute-over-prithviraj-road-bungalow/131548522?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-48970/131548522.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Delhi government to invoke DMA Act, empower DMs to act against unauthorised construction", "para": "Delhi government will recover losses from corrupt officials and invoke the Disaster Management Act 2005 following a fatal hotel fire. Chief Minister Rekha Gupta announced that negligent officials will face up to two years imprisonment and fines, with recovery of losses from their salaries, pensions, and properties.", "href": "https://realty.economictimes.indiatimes.com/news/industry/delhi-government-takes-strong-action-against-unauthorised-construction-following-hotel-fire/131544041?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-39482/131544041.cms?width=150&height=112", "tag": "industry"}, {"title": "Karnataka HC upholds land acquisition for Bengaluru\u2019s Banashankari VI Stage project", "para": "The Karnataka High Court has upheld the land acquisition for Bengaluru's Banashankari VI Stage project, reversing a single bench's decision. The division bench ruled that once land is acquired free of encumbrances, it cannot be quashed, imposing a Rs 50,000 cost on landowners for abusing the court process.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/karnataka-high-court-upholds-land-acquisition-for-banashankari-vi-stage-project-in-bengaluru/131544021?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-70844/131544021.cms?width=150&height=112", "tag": "regulatory"}]}
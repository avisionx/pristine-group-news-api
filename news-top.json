{"updated_at": {"date": {"d": "20", "m": "03", "Y": "2026"}, "time": {"H": "10", "M": "26", "S": "49"}}, "news": [{"title": "Onward Workspaces lease out 1.65 lakh sq ft office space to Accenture in Noida", "para": "Onward Workspaces has leased 1.65 lakh sq ft of office space to Accenture in Noida's sector 132, accommodating 1,460 workstations across eight floors. This significant deal expands Onward Workspaces' managed portfolio to over eight lakh sq ft in Delhi NCR. The company is also developing a new co-working center in Connaught Place.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/onward-workspaces-lease-out-1-65-lakh-sq-ft-office-space-to-accenture-in-noida/129698024?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-82988/129698024.cms?width=150&height=112", "tag": "commercial"}, {"title": "Property mutation portal for Mumbai launched; provides fully online service", "para": "Mumbai has launched a new online portal for property mutations. Property owners, including NRIs, can now apply for name transfers and other changes from anywhere. This digital service eliminates the need to visit government offices. The portal offers real-time SMS alerts and online status tracking for 45 types of property changes. A help desk is available for technical assistance.", "href": "https://realty.economictimes.indiatimes.com/news/technology/property-mutation-portal-for-mumbai-launched-provides-fully-online-service/129697297?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-103039/129697297.cms?width=150&height=112", "tag": "technology"}, {"title": "NBCC to develop \u20b95,800 crore Rajasthan Mandapam in Jaipur", "para": "NBCC India will develop Rajasthan Mandapam and allied infrastructure near Jaipur International Airport on over 90 acres, with a project value exceeding \u20b95,800 crore. The master plan includes a convention center, expo halls, IT/ITES spaces, hotels, retail, housing, a museum, and a fintech plaza. NBCC will implement this self-financing project, with tenders expected in April 2026.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/rajasthan-mandapam-nbccs-5800-crore-development-project-in-jaipur/129696939?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-134482/129696939.cms?width=150&height=112", "tag": "allied-industries"}]}
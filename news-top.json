{"updated_at": {"date": {"d": "15", "m": "05", "Y": "2026"}, "time": {"H": "08", "M": "36", "S": "10"}}, "news": [{"title": "Kolkata metro's orange line extension till sector V likely by December 2026", "para": "Kolkata Metro Railway is set to extend its Orange Line services to Sector V by December 2026. Essential viaduct work at the Chingrighata crossing begins this Friday. This will bridge a critical gap, facilitating the much-needed connection between southern suburbs and Sector V. Permissions have been granted for traffic blocks to complete this vital project.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/kolkata-metros-orange-line-extension-to-sector-v-set-for-december-2026-completion/131111897?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-94324/131111897.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Nisus Finance invests \u20b990 crore in Realnet Ventures' project in Pune's Hinjewadi", "para": "Nisus Finance Services has injected \u20b990 crore into Realnet Ventures, a Paranjape Schemes subsidiary, for a residential project in Pune's Blue Ridge township. This investment targets an 188-unit apartment tower with 3BHK and 4BHK configurations, boasting a significant saleable area and a projected gross development value of \u20b9370 crore. The development is situated within a 150-acre mixed-use township.", "href": "https://realty.economictimes.indiatimes.com/news/industry/nisus-finance-invests-90-crore-in-realnet-ventures-pune-project/131112355?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-40622/131112355.cms?width=150&height=112", "tag": "industry"}, {"title": "Maharashtra approves handover of three plots for Mula-Mutha riverfront development project", "para": "The Maharashtra state government has approved the transfer of three land plots totaling 52,851 sqm for Pune's riverfront development project. The Standing Committee also greenlit extending the project from Mundhwa to Manjari and sanctioned land for a garbage transfer unit. Additionally, a heritage conservation project for the Peshwa-era water supply system was approved.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/maharashtra-government-approves-land-transfer-for-mula-mutha-riverfront-development/131111726?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1775611/131111726.cms?width=150&height=112", "tag": "infrastructure"}]}
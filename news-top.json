{"updated_at": {"date": {"d": "29", "m": "04", "Y": "2026"}, "time": {"H": "05", "M": "17", "S": "07"}}, "news": [{"title": "Maharashtra government moves closer to seal Air India building buyout after \u20b91,600 crore fund transfer", "para": "Maharashtra government is set to acquire the iconic Air India building in Mumbai. The Finance Department has transferred Rs 1,600 crore to the Public Works Department. The agreement is expected to be signed within two weeks. The state plans to renovate the 23-storey structure and shift government offices there.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/maharashtra-government-moves-closer-to-seal-air-india-building-buyout-after-1600-crore-fund-transfer/130595339?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-130432/130595339.cms?width=150&height=112", "tag": "commercial"}, {"title": "Soon high-rises on nine-metres roads across Mumbai", "para": "Mumbai's BMC is easing building height restrictions, allowing skyscrapers on narrow roads. An amendment to DCPR 2034 introduces graded height permissions based on road width, potentially unlocking redevelopment for thousands of old buildings. While boosting urban renewal, concerns remain about infrastructure strain and emergency access.", "href": "https://realty.economictimes.indiatimes.com/news/industry/mumbai-set-to-soar-high-rises-approved-on-9-metre-roads/130595025?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-29210/130595025.cms?width=150&height=112", "tag": "industry"}, {"title": "Haryana set to make EV charging points mandatory in societies, malls & offices", "para": "Haryana's Building Code is being amended to mandate EV charging infrastructure in new residential and non-residential projects. This move aims to accelerate electric vehicle adoption by ensuring charging facilities are integrated from the planning stage, with exemptions from Floor Area Ratio calculations to encourage developer participation.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/haryana-to-mandate-ev-charging-points-for-all-new-buildings/130594911?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-151224/130594911.cms?width=150&height=112", "tag": "infrastructure"}]}
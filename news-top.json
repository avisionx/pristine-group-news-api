{"updated_at": {"date": {"d": "16", "m": "06", "Y": "2026"}, "time": {"H": "22", "M": "03", "S": "52"}}, "news": [{"title": "Kalki Koechlin sells apartment in Mumbai for \u20b92.55 crore", "para": "Actress Kalki Koechlin has sold her Mumbai apartment in Varsova Kiran Co-operative Housing Society for \u20b92.55 crore. Purchased in 2015 for \u20b91.95 crore, the sale reflects an appreciation of approximately \u20b960 lakh over a decade. The transaction, registered in April 2026, saw a stamp duty payment of \u20b916.08 lakh.", "href": "https://realty.economictimes.indiatimes.com/news/residential/kalki-koechlin-sells-mumbai-apartment-for-255-crore-a-profitable-investment/131767135?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-141974/131767135.cms?width=150&height=112", "tag": "residential"}, {"title": "From Krishna Curve to Krishna CONIQ: Redefining the future of urban retail destinations", "para": "Krishna United Group is transforming Mumbai's Linking Road into a lifestyle hub. Following the success of Krishna Curve, the company is launching Krishna CONIQ. This ambitious project integrates retail, dining, entertainment, and office spaces. It aims to create an immersive experience engaging all five senses. Krishna CONIQ represents the future of urban retail and lifestyle destinations in India.", "href": "https://realty.economictimes.indiatimes.com/news/brand-connect-initiative/krishna-coniq-revolutionizing-urban-retail-with-experience-driven-design/131762749?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-14634/131762749.cms?width=150&height=112", "tag": "brand-connect-initiative"}, {"title": "Delhi: Crackdown on illegal constructions ramps up; 217 properties razed, 237 sealed in June so far", "para": "The Municipal Corporation of Delhi has intensified its crackdown on illegal constructions. On Monday, 14 properties were demolished and 25 establishments sealed. This drive follows a hotel fire incident. Since then, 217 properties have been demolished and 237 sealed.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/delhi-intensifies-crackdown-on-illegal-constructions-217-properties-demolished-and-237-sealed-in-june/131773348?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-542884/131773348.cms?width=150&height=112", "tag": "infrastructure"}]}
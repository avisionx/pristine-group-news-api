{"updated_at": {"date": {"d": "16", "m": "11", "Y": "2025"}, "time": {"H": "20", "M": "10", "S": "17"}}, "news": [{"title": "Collectors in Goa told to upload land conversion sanads online", "para": "Goa State Information Commission has ordered district collectors to put land conversion sanad details online. This follows a complaint about non-compliance with the Right to Information Act. Applicants' names, addresses, survey numbers, and conversion dates will be uploaded. The directive applies to both South and North Goa districts.", "href": "https://realty.economictimes.indiatimes.com/news/technology/goa-collectors-ordered-to-make-land-conversion-sanads-public-online/125346015?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-219748/125346015.cms?width=150&height=112", "tag": "technology"}, {"title": "Smart city to conduct full study on Panaji revitalisation", "para": "Imagine Panaji Smart City Development Limited will conduct a comprehensive study to assess the condition of core business zone and heritage buildings. The project, funded by a special assistance scheme, will analyze roads, drains, and waterworks, and identify restoration needs for heritage structures, particularly in Fontainhas. The study aims to preserve Portuguese-era architecture and modernize city infrastructure.", "href": "https://realty.economictimes.indiatimes.com/news/smart-city/panajis-smart-city-initiative-launches-comprehensive-revitalisation-study/125345980?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-55500/125345980.cms?width=150&height=112", "tag": "smart-city"}, {"title": "Bhubaneswar: Department upholds demolition of unauthorised five-storey residential building in Balianta", "para": "The housing department upheld a demolition order for an unauthorised five-storey building in Andilo, Balianta. A promoter and homebuyers' appeal was dismissed after they attempted to bypass BDA approval, relying on an old gram panchayat plan. The structure, built without NOCs, will be demolished with costs recoverable from the promoter and landowners.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/bhubaneswar-authority-enforces-demolition-of-illegal-five-storey-building-in-balianta/125345938?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-77906/125345938.cms?width=150&height=112", "tag": "infrastructure"}]}
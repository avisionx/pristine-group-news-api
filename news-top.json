{"updated_at": {"date": {"d": "06", "m": "05", "Y": "2026"}, "time": {"H": "05", "M": "18", "S": "19"}}, "news": [{"title": "Scrutiny on building sites using potable water in DLF phases in Gurugram", "para": "DLF City phases are witnessing a crackdown on illegal potable water extraction at construction sites, with motors removed from seven locations. Officials are urging fines and emphasizing the need for non-potable sources to ensure residents receive uninterrupted water supply amidst rising urban demand and declining groundwater levels.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/gurugram-cracks-down-on-illegal-potable-water-use-at-construction-sites/130842858?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-84552/130842858.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "ITAT allows capital gains tax exemption against property bought from in-laws", "para": "The Mumbai ITAT ruled that purchasing property from relatives is not a sham transaction solely for tax benefits. The tribunal allowed a Rs 41.5 crore exemption under Section 54F, stating that genuine intra-family deals, backed by documentation, cannot be disregarded based on suspicion of tax avoidance.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/itat-rules-for-capital-gains-tax-exemption-on-in-law-property-transactions/130842801?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-106642/130842801.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Odisha RERA allows hard copy submission for offline registered projects", "para": "The Odisha Real Estate Regulatory Authority (ORERA) has revised its quarterly progress report formats for builders, allowing hard-copy submissions for offline-registered projects. These changes, effective from June 2026, aim to enhance transparency and compliance by making disclosures outcome-oriented and capturing detailed project advancement beyond basic construction.", "href": "https://realty.economictimes.indiatimes.com/news/rera/odisha-rera-introduces-hard-copy-qpr-submission-for-improved-project-transparency/130842688?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-40164/130842688.cms?width=150&height=112", "tag": "rera"}]}
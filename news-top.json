{"updated_at": {"date": {"d": "26", "m": "05", "Y": "2026"}, "time": {"H": "18", "M": "14", "S": "14"}}, "news": [{"title": "Prayagraj civic body to launch OTS scheme for house tax arrear in June 2026", "para": "Prayagraj Municipal Corporation is launching a One Time Settlement (OTS) scheme in early June, waiving interest on pending house tax dues for over 90,000 property owners. This four-month scheme aims to recover Rs 125 crore in outstanding taxes, including Rs 90 crore in waived interest, benefiting both residential and commercial defaulters.", "href": "https://realty.economictimes.indiatimes.com/news/residential/prayagraj-civic-body-to-offer-major-house-tax-relief-with-upcoming-ots-scheme/131334164?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-37030/131334164.cms?width=150&height=112", "tag": "residential"}, {"title": "ED conducts searches in Punjab in real estate 'fraud' case", "para": "The Enforcement Directorate has conducted searches across Punjab and Chandigarh targeting a real estate company and its promoters in a money laundering probe. The investigation is linked to alleged fraud against the Greater Mohali Area Development Authority (GMADA), involving substantial outstanding liabilities and diversion of project funds.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ed-conducts-raids-in-punjab-over-alleged-real-estate-fraud/131333462?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-303262/131333462.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Grade-A office vacancy may decline 50 bps this fiscal: Crisil", "para": "Vacancy in India\u2019s Grade A commercial office market is expected to decline by about 50 basis points to 15.5-16% by the end of the current fiscal, according to Crisil Ratings. The decline will be supported by net leasing growth, demand from flexible workspace operators and GCCs, and scheduled completion of ongoing projects, though global uncertainty and AI-led disruption remain key risks.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/grade-a-office-vacancy-may-decline-50-bps-this-fiscal-crisil/131334452?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-200768/131334452.cms?width=150&height=112", "tag": "commercial"}]}
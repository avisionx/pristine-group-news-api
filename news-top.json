{"updated_at": {"date": {"d": "28", "m": "05", "Y": "2026"}, "time": {"H": "05", "M": "59", "S": "35"}}, "news": [{"title": "Visible road dust, construction waste found during inspection drive in Ghaziabad", "para": "An inspection by the Commission for Air Quality Management (CAQM) in Ghaziabad revealed 24 instances of high visible road dust and construction waste. The commission has directed authorities to intensify dust mitigation measures, including mechanized sweeping and water sprinkling, to address the issue.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/ghaziabads-air-quality-under-threat-road-dust-and-construction-waste-discovered/131362830?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-95740/131362830.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Hyderabad sinks deeper into groundwater crisis, worst-hit metro: Report", "para": "Hyderabad has been identified as India's most critically affected metro for groundwater depletion, with 26 units classified as 'critical' or 'over-exploited'. This alarming situation is attributed to rampant borewell drilling and inadequate rainwater harvesting, pushing water tables to unprecedented depths.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/hyderabad-faces-critical-groundwater-crisis-over-exploitation-report/131362800?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-2028869/131362800.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Chhattisgarh HC halts sand mining tender over incomplete survey report", "para": "The Chhattisgarh High Court has cancelled a sand mining tender in Janjgir-Champa district. The court ruled that mining cannot proceed without an approved District Survey Report. A draft report uploaded online is not sufficient. The Gram Panchayat of Hathnewra had challenged the tender. The court emphasized the need for public objections before finalizing the report.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/chhattisgarh-high-court-halts-controversial-sand-mining-tender-over-invalid-survey-report/131362648?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1779109/131362648.cms?width=150&height=112", "tag": "allied-industries"}]}
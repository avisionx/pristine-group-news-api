{"updated_at": {"date": {"d": "10", "m": "06", "Y": "2026"}, "time": {"H": "07", "M": "57", "S": "46"}}, "news": [{"title": "Indore tops in generating revenue from property registration", "para": "Madhya Pradesh's stamp duty and property registration earnings surged by 12.82% in the first two months of the fiscal year, reaching Rs 1,843.54 crore. This growth, driven by higher guideline values and property prices, outpaced a modest 4% increase in transaction volumes. Indore led revenue collections with Rs 328.45 crore.", "href": "https://realty.economictimes.indiatimes.com/news/residential/indore-leads-madhya-pradesh-in-property-registration-revenue-growth/131624845?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-29278/131624845.cms?width=150&height=112", "tag": "residential"}, {"title": "IT Park in Mangaluru tender draws no bids, deadline extended", "para": "Mangaluru's Rs 135 crore IT Park project faces another delay as no bidders have emerged, forcing an extension of the tender deadline. Poor connectivity due to a narrow approach road and restrictive tender conditions, including high deposit requirements and consortium limitations, are cited as major deterrents by potential investors.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/no-bids-for-mangaluru-it-park-tender-government-extends-deadline-amid-connectivity-concerns/131624824?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-22278/131624824.cms?width=150&height=112", "tag": "commercial"}, {"title": "Lucknow: Fire department issues notices to 20 hotels for fire safety violations", "para": "Lucknow's fire department has issued notices to twenty hotels and restaurants following a citywide inspection. Twelve establishments have been given forty-five days to fix structural deficiencies. The inspections revealed critical gaps in emergency exits, staircases, and firefighting systems. Officials are emphasizing public safety and will take strict action against persistent violations.", "href": "https://realty.economictimes.indiatimes.com/news/hospitality/lucknow-fire-department-cracks-down-on-hotels-for-safety-violations/131624759?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-78088/131624759.cms?width=150&height=112", "tag": "hospitality"}]}
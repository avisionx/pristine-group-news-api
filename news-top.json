{"updated_at": {"date": {"d": "02", "m": "04", "Y": "2026"}, "time": {"H": "10", "M": "40", "S": "56"}}, "news": [{"title": "Vijayawada civic body posts \u20b9267 crore tax collection in FY26", "para": "Vijayawada Municipal Corporation achieved a significant tax collection of Rs 267.10 crore for the 2025-26 financial year. This marks a Rs 15 crore improvement over the previous year's collection.  The civic body's efforts in tracing vacant land tax owners and taking lawful actions contributed to this revenue growth. The target for the upcoming financial year is set at 90% collection.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/vijayawada-municipal-corporation-achieves-267-crore-tax-collection-in-fy26/129970934?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-54700/129970934.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Belagavi: Property tax collection of BCC rises to \u20b970.8 crore, but target remains elusive", "para": "Belagavi City Corporation collected Rs 70.8 crore in property tax for FY 2025-26, falling short of its Rs 89.4 crore target. Officials cited election duties and census work as reasons for the shortfall. The target for FY 2026-27 is projected to exceed Rs 92 crore, with ongoing census work posing further challenges.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/belagavi-city-corporation-fails-to-meet-property-tax-collection-target-for-2025-26/129970893?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-34554/129970893.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Lucknow development body survey's to curb fraud, update records", "para": "The Lucknow Development Authority (LDA) has initiated a door-to-door property verification drive to update its records and prevent fraud. A private agency is conducting the survey, collecting details like mobile numbers and ownership documents from residents. This initiative aims to digitize records, improve services, and mitigate risks of disputes and fraudulent transactions.", "href": "https://realty.economictimes.indiatimes.com/news/industry/lucknow-development-authority-launches-property-verification-to-combat-fraud/129970843?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-20204/129970843.cms?width=150&height=112", "tag": "industry"}]}
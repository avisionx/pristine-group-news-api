{"updated_at": {"date": {"d": "10", "m": "11", "Y": "2025"}, "time": {"H": "18", "M": "15", "S": "00"}}, "news": [{"title": "Chandigarh to set up 17 more sites for construction waste disposal", "para": "Chandigarh Municipal Corporation is establishing 17 new dedicated sites for construction and demolition waste to address increasing generation. The civic body aims for at least one collection point per ward to facilitate responsible disposal and curb illegal dumping. An agency has been hired to construct these sites, with progress pending site allocation.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/chandigarh-to-set-up-17-more-sites-for-construction-waste-disposal/125223466?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-112534/125223466.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "About 11 illegal buildings set to be razed in Bengaluru", "para": "Bengaluru East city corporation has commenced the demolition of 11 illegal structures found with significant deviations from approved building plans. A building in Whitefield with multiple unauthorized floors is currently being dismantled manually. This action follows a survey of over 600 under-construction buildings and the issuance of notices.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/bengaluru-takes-action-11-illegal-buildings-set-for-demolition/125223495?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-62880/125223495.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Bhubaneswar civic body plans to include 72 villages under its ambit", "para": "The Bhubaneswar Municipal Corporation plans to incorporate 72 revenue villages into its jurisdiction following consent from the villages. This expansion will see the administrative zones increase from three to six, bringing services like sanitation and water supply to the newly added areas.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/bhubaneswar-municipal-corporation-plans-expansion-to-include-72-villages/125223350?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-91240/125223350.cms?width=150&height=112", "tag": "infrastructure"}]}
{"updated_at": {"date": {"d": "13", "m": "04", "Y": "2026"}, "time": {"H": "04", "M": "48", "S": "37"}}, "news": [{"title": "Construction firm accused of cheating customers by failing to deliver villas in Kollur, Telangana", "para": "A Hyderabad construction firm faces cheating accusations after allegedly collecting crores from customers for villas in Kollur without delivering possession. The company lured buyers with a pre-launch offer, accepting substantial deposits before securing necessary RERA and HMDA permissions. A criminal case has been registered against the management for criminal breach of trust and cheating.", "href": "https://realty.economictimes.indiatimes.com/news/residential/customers-accuse-telangana-construction-firm-of-cheating-in-villa-project/130223195?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-90278/130223195.cms?width=150&height=112", "tag": "residential"}, {"title": "Goa: Over 18,000 sq meters land converted in Bardez to settlement zones", "para": "The Town and Country Planning department has granted final approvals for six zone change proposals, converting over 18,000 sqm of land to settlement zones, primarily in Bardez and Pernem. These approvals, concentrated in Sircaim and Mandrem, are subject to the outcome of pending writ petitions before the Bombay High Court.", "href": "https://realty.economictimes.indiatimes.com/news/industry/goa-approves-over-18000-sqm-land-conversion-to-settlement-zones-in-bardez/130222942?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-235538/130222942.cms?width=150&height=112", "tag": "industry"}, {"title": "About 24 industrial plots up for grabs across Greater Noida sectors", "para": "Greater Noida Industrial Development Authority has launched a scheme offering 24 industrial plots to attract investment and boost growth. The plots, ranging from 9,000 sqm to 1 lakh sqm, are located across multiple sectors and aim to enhance the region's manufacturing and logistics appeal. Applications are open until May 12, with evaluation based on financial strength and employment potential.", "href": "https://realty.economictimes.indiatimes.com/news/industry/about-24-industrial-plots-up-for-grabs-across-greater-noida-sectors/130222878?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-242108/130222878.cms?width=150&height=112", "tag": "industry"}]}
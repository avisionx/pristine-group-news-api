{"updated_at": {"date": {"d": "08", "m": "04", "Y": "2026"}, "time": {"H": "08", "M": "49", "S": "59"}}, "news": [{"title": "Ranchi civic body targets illegal commercial enterprises in residential areas", "para": "The Ranchi Municipal Corporation is cracking down on illegal commercial establishments operating in residential Jharkhand State Housing Board colonies. Enforcement teams are conducting door-to-door surveys and cancelling trade licenses in areas like Harmu and Bariatu, following Supreme Court norms on land use. This action aims to prevent residential areas from becoming commercial hubs, disturbing civic planning and infrastructure.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/ranchi-civic-body-cracks-down-on-illegal-commercial-activities-in-residential-areas/130102287?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-75352/130102287.cms?width=150&height=112", "tag": "commercial"}, {"title": "Mangaluru civic body plans construction & demolition waste unit at Pachanady", "para": "Mangaluru City Corporation is planning to reserve land at Pachanady for scientific management of construction and demolition waste. Builders will be charged a fee to use this facility, and hefty penalties will be imposed on those caught dumping waste in public places or near rivers. This move aims to curb rampant illegal dumping.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/mangaluru-plans-cd-waste-management-unit-at-pachanady-to-curb-illegal-dumping/130102254?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-268506/130102254.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "RBI keeps policy rate unchanged at 5.25% amid inflationary pressure", "para": "The Reserve Bank of India has chosen to hold its key interest rate at 5.25 percent, a step that reflects a cautious optimism amidst improving global economic sentiments following a ceasefire in the US-Iran tensions. This policy decision is crucial for India's import-driven market, as it underscores a commitment to managing inflation in line with the government's fresh targets.", "href": "https://realty.economictimes.indiatimes.com/news/industry/rbi-keeps-policy-rate-unchanged-at-5-25-amid-inflationary-pressure/130103340?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1700923/130103340.cms?width=150&height=112", "tag": "industry"}]}
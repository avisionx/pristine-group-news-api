{"updated_at": {"date": {"d": "17", "m": "11", "Y": "2025"}, "time": {"H": "06", "M": "16", "S": "46"}}, "news": [{"title": "Pimpri Chinchwad civic body seals nine RMC plants for violation of environmental norms", "para": "Nine ready-mix concrete plants in Pimpri Chinchwad have been sealed for violating environmental norms, including inadequate dust control and open mixing. This action follows a crackdown by the municipal corporation and the Maharashtra Pollution Control Board due to rising air pollution. Residents had complained about dust and debris from these plants, contributing to a significant drop in air quality.", "href": "https://realty.economictimes.indiatimes.com/news/cement/pimpri-chinchwad-seals-nine-rmc-plants-for-environmental-violations-amid-rising-air-pollution/125376009?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-130774/125376009.cms?width=150&height=112", "tag": "cement"}, {"title": "Odisha HC allows vigilance court trial in BDA plot allotment scam case", "para": "The Orissa High Court has refused to discharge former Bhubaneswar Development Authority officials accused in a 2014 plot allotment scam. The court found sufficient material for the trial to proceed. The vigilance probe alleges irregular allotment of commercial plots to relatives of officials without advertisement and at low prices.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/odisha-high-court-greenlights-bda-plot-allotment-scam-trial/125375950?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-188006/125375950.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Greater Noida authority launches \u20b93,600-crore commercial plot scheme", "para": "Greater Noida Industrial Development Authority has launched a major commercial land scheme, offering 37 plots with a combined reserve price of Rs 3,604 crore. These plots, designated for commercial complexes, retail hubs, and mixed-use developments, are available through e-auction. Registrations are open until December 5, with plot sizes and prices varying across several key sectors.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/greater-noida-launches-3600-crore-commercial-land-scheme-to-boost-development/125375905?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-242505/125375905.cms?width=150&height=112", "tag": "commercial"}]}
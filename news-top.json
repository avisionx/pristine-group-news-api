{"updated_at": {"date": {"d": "26", "m": "04", "Y": "2026"}, "time": {"H": "10", "M": "35", "S": "02"}}, "news": [{"title": "India Cements' profit jumps fourfold to \u20b959 crore in Q4 FY26", "para": "India Cements Ltd. witnessed a significant surge in its March quarter net profit, soaring to Rs 59.5 crore from Rs 14.67 crore a year ago. This impressive growth was fueled by a substantial 18% increase in domestic sales volume and improved sales realization.", "href": "https://realty.economictimes.indiatimes.com/news/cement/india-cements-reports-record-profit-growth-in-q4-fy26/130520076?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-20592/130520076.cms?width=150&height=112", "tag": "cement"}, {"title": "ED raids against Raheja Developers in home buyers 'fraud' case", "para": "The Enforcement Directorate has conducted fresh searches against Raheja Developers in Delhi-NCR as part of a money laundering probe linked to alleged fraud with home buyers. The investigation focuses on the non-delivery of flats in the 'Raheja Revanta' project. The company denies wrongdoing, citing project delays due to a lack of essential government infrastructure.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ed-conducts-raids-on-raheja-developers-over-alleged-home-buyers-fraud/130519944?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-205292/130519944.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Andhra Pradesh high court orders demolition of illegal Thotlakonda resort", "para": "The Andhra Pradesh High Court has ordered the demolition of illegal structures at a beach resort near the Thotlakonda Buddhist monument. The resort, built on land leased by APTDC and allegedly subleased for unauthorized expansion including permanent concrete structures, violated Coastal Regulation Zone norms. The court directed the GVMC to demolish the constructions within three weeks.", "href": "https://realty.economictimes.indiatimes.com/news/hospitality/andhra-pradesh-high-court-orders-demolition-of-illegal-beach-resort-at-thotlakonda/130512908?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-33472/130512908.cms?width=150&height=112", "tag": "hospitality"}]}
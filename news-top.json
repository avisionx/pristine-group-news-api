{"updated_at": {"date": {"d": "03", "m": "03", "Y": "2026"}, "time": {"H": "04", "M": "03", "S": "42"}}, "news": [{"title": "SC issues notice to Goa government, developer for construction of villas at Siolim", "para": "The Supreme Court has issued notices to the Goa government and a project developer. This follows a challenge to a High Court order that dismissed a plea against building eight luxury villas at Oxel in Siolim. The petitioner argues the project threatens the 363-year-old Oxel spring, a vital water source for residents facing a deficit. The court's decision is awaited.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/supreme-court-challenges-goa-government-over-luxury-villas-in-siolim/128957817?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-84940/128957817.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Ghaziabad development body to take help of brokers, marketing cell to sell 1,700 flats", "para": "Ghaziabad Development Authority plans to sell over 1,700 unsold houses. Professional brokers will be hired to find buyers. A marketing cell will also be established. This strategy aims to generate over Rs 500 crore. The initiative will not apply to EWS flats. This follows a similar state government scheme.", "href": "https://realty.economictimes.indiatimes.com/news/residential/ghaziabad-development-authority-partners-with-brokers-to-sell-1700-unsold-flats/128957773?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-132302/128957773.cms?width=150&height=112", "tag": "residential"}, {"title": "HC asks Greater Noida authority to restore plot it cancelled nine years ago", "para": "The Allahabad High Court has reinstated a Rs 100 crore farmhouse plot to SDS Infratech, overturning a nine-year-old cancellation by the Greater Noida Authority. The court directed the authority to decide on the developer's zero-period relief claim within four months, quashing the 2017 cancellation order.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/allahabad-high-court-restores-rs-100-crore-farmhouse-plot-to-sds-infratech/128957747?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1448031/128957747.cms?width=150&height=112", "tag": "regulatory"}]}
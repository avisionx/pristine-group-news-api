{"updated_at": {"date": {"d": "14", "m": "11", "Y": "2025"}, "time": {"H": "00", "M": "50", "S": "08"}}, "news": [{"title": "Delhi civic body to install CCTV cameras at 524 spots to tackle construction dumping", "para": "The Municipal Corporation of Delhi (MCD) is installing CCTV cameras at 524 locations to combat illegal dumping of construction and demolition waste. This initiative aims to identify and penalize habitual offenders, complementing existing designated dumping sites and processing plants. The city generates substantial C&D waste daily, with efforts underway to increase processing capacity and improve waste management infrastructure.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/mcd-to-combat-construction-waste-524-cctv-cameras-to-be-installed-in-delhi/125293965?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-93654/125293965.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Sub-registrar, realtor arrested in land-grab case in Bengaluru", "para": "Bengaluru CCB sleuths have arrested a sub-registrar and a realtor-cum-middleman in a land-grab case involving forged documents and the sale of multiple residential sites without the landowner's knowledge. The August 2022 case, initially filed at Parappana Agrahara police station, has led to the arrest of approximately 100 suspects so far.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/sub-registrar-and-realtor-arrested-in-major-bengaluru-land-grabbing-scandal/125293915?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-32062/125293915.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Telangana RERA directs Aliens Developers to refund \u20b92 lakh to homebuyer", "para": "Telangana RERA has ordered Aliens Developers Pvt Ltd to refund \u20b92 lakh to a homebuyer within 30 days. The buyer had paid a booking advance for a flat in the 'Aliens Space Station' project and received a partial refund after cancellation. The developer's claim of full refund and contractual dispute was dismissed by RERA.", "href": "https://realty.economictimes.indiatimes.com/news/rera/telangana-rera-orders-aliens-developers-to-refund-2-lakh-to-homebuyer/125293880?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-42180/125293880.cms?width=150&height=112", "tag": "rera"}]}
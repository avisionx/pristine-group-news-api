{"updated_at": {"date": {"d": "06", "m": "05", "Y": "2026"}, "time": {"H": "19", "M": "18", "S": "22"}}, "news": [{"title": "Mahindra Lifespaces and Sattva Group launch residential projects in Mumbai", "para": "Mahindra Lifespace Developers has launched Mahindra BeaconHill, a 58-storey residential project in Mahalaxmi, South Mumbai, with a potential GDV of \u20b91,650 crore. In a separate development, Sattva Group has introduced Sattva Sumera, its first Mumbai residential project, a \u20b95,500 crore development featuring twin towers with over 20 lakh sq ft of space.", "href": "https://realty.economictimes.indiatimes.com/news/residential/mahindra-lifespaces-and-sattva-group-unveil-major-residential-projects-in-mumbai/130861881?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-54028/130861881.cms?width=150&height=112", "tag": "residential"}, {"title": "Brigade Enterprises' net profit rises by 6.51% to \u20b9724.76 crore in FY26", "para": "Brigade Enterprises announced a 6.51 percent rise in its net profit for the financial year 2025-26. The company's profit after tax reached \u20b9724.76 crore. Total income also grew by 11.21 percent. The board recommended a dividend and approved a bonus share issue. Real estate sales and leasing business showed strong performance. The hospitality segment also reported revenue growth.", "href": "https://realty.economictimes.indiatimes.com/news/industry/brigade-enterprises-reports-651-increase-in-net-profit-for-fy26/130861660?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-52966/130861660.cms?width=150&height=112", "tag": "industry"}, {"title": "NOC for constructions near defence establishments cannot be insisted belatedly: Bombay HC", "para": "The Bombay High Court declared that late demands for No Objection Certificates regarding construction adjacent to defense facilities are not permissible. The court mandated that authorities grant occupancy certificates for two residential buildings located near INS Trata. It emphasized that any security issues must be identified and resolved at the outset of construction.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/noc-for-constructions-near-defence-establishments-cannot-be-insisted-belatedly-bombay-hc/130857222?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-344912/130857222.cms?width=150&height=112", "tag": "regulatory"}]}
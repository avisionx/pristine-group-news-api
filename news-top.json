{"updated_at": {"date": {"d": "17", "m": "04", "Y": "2026"}, "time": {"H": "07", "M": "17", "S": "10"}}, "news": [{"title": "Online khata correction facility in Bengaluru soon", "para": "The Greater Bengaluru Authority is set to launch an online khata correction facility, simplifying property record updates for citizens. This new system will allow corrections to details like location and ward number, excluding owner names and property measurements.", "href": "https://realty.economictimes.indiatimes.com/news/technology/bengaluru-introduces-online-khata-correction-for-easier-property-updates/130322547?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-75464/130322547.cms?width=150&height=112", "tag": "technology"}, {"title": "Lucknow development body to offer 630 flats in Atalnagar scheme", "para": "Lucknow Development Authority (LDA) will open registrations for 630 budget housing flats under the Atalnagar scheme from April 18 to May 17. The project in Devpur Para offers one and two-bedroom units priced from Rs 9.82 lakh, with amenities like water, electricity, and parking. A lottery will be used for allotment.", "href": "https://realty.economictimes.indiatimes.com/news/residential/get-your-home-630-budget-flats-available-in-atalnagar-lucknow/130322517?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-47686/130322517.cms?width=150&height=112", "tag": "residential"}, {"title": "Suraj Estate Developers acquires land for \u20b918 crore in Dadar West, Mumbai", "para": "Suraj Estate Developers has acquired a land parcel in Mumbai\u2019s Dadar West for a total consideration of \u20b918 crore, including cash and area sharing. The company plans to redevelop the plot with an estimated gross development value of around \u20b9100 crore.", "href": "https://realty.economictimes.indiatimes.com/news/industry/suraj-estate-developers-acquires-land-for-18-crore-in-dadar-west-mumbai/130322428?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-510500/130322428.cms?width=150&height=112", "tag": "industry"}]}
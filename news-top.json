{"updated_at": {"date": {"d": "19", "m": "03", "Y": "2026"}, "time": {"H": "12", "M": "35", "S": "54"}}, "news": [{"title": "Vadodara: Man cheats 16 of \u20b940 lakh in PMAY flat scam", "para": "Vadodara police have registered a cheating case against Harish Chauhan, who allegedly defrauded 16 individuals by promising PMAY flats.  Chauhan, posing as a VMC agent, collected approximately Rs 40 lakh from victims before disappearing.  One complainant reported paying Rs 6.83 lakh for a promised flat in Subhanpura. The accused is currently absconding.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/fraudster-dupes-16-victims-of-40-lakh-in-pmay-scam/129679777?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-57802/129679777.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Karnataka eyes Japan partnership for smart city solutions in Bengaluru", "para": "Karnataka is set to collaborate with Japan on smart city initiatives in Bengaluru, aiming to leverage Japanese expertise for urban challenges. This partnership, facilitated by Japan's MLIT, will focus on areas like energy, wastewater, mobility, and disaster management, with the Greater Bengaluru Authority acting as the nodal agency.", "href": "https://realty.economictimes.indiatimes.com/news/smart-city/karnataka-and-japan-forge-alliance-for-innovative-smart-city-solutions-in-bengaluru/129679751?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-81876/129679751.cms?width=150&height=112", "tag": "smart-city"}, {"title": "UltraTech Cement to acquire 26.18% stake in Sunsure Solarpark for \u20b919.2 crore", "para": "UltraTech Cement is going green by investing up to \u20b919.2 crore in a stake of Sunsure Solarpark Seven. With this initiative, the company aims to tap into renewable energy, curbing its electricity expenses and fulfilling environmental regulations. The deal, which will be finalized with a cash infusion, is projected to be completed in 180 days.", "href": "https://realty.economictimes.indiatimes.com/news/cement/ultratech-cement-to-acquire-26-18-stake-in-sunsure-solarpark-for-19-2-crore/129669528?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-63542/129669528.cms?width=150&height=112", "tag": "cement"}]}
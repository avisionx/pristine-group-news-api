{"updated_at": {"date": {"d": "08", "m": "06", "Y": "2026"}, "time": {"H": "17", "M": "17", "S": "22"}}, "news": [{"title": "PLOTRIX: How Kaushall Prakash is rewriting the real estate development playbook through the DM model", "para": "India's real estate industry has long struggled with flawed execution models, leaving landowners with limited options. PLOTRIX introduces a Development & Marketing Management (DM) Model, offering a structured, accountable framework for end-to-end project execution. This innovative approach aims to maximize value and transparency, addressing the industry's core challenges.", "href": "https://realty.economictimes.indiatimes.com/news/brand-connect-initiative/revolutionizing-real-estate-plotrixs-innovative-dm-model-by-kaushall-prakash/131591754?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-32070/131591754.cms?width=150&height=112", "tag": "brand-connect-initiative"}, {"title": "Builder-bank nexus case: CBI files charge sheet against Ninex Developers, its director", "para": "The CBI has filed a charge sheet against Ninex Developers Ltd and its director for alleged fraudulent activities in a Gurugram housing project. This marks the CBI's 11th report in builder-banker nexus cases, where thousands of homebuyers were reportedly cheated through deceptive promises and misleading representations.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/cbi-charges-ninex-developers-in-builder-banker-nexus-fraud-case/131592513?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-42880/131592513.cms?width=150&height=112", "tag": "regulatory"}, {"title": "SC directs execution of settlement in Ardee group family dispute", "para": "The Supreme Court has ordered the execution of a settlement in a property dispute concerning the Ardee Group and family assets of the late Ashok Varma. Daughters Shefali Varma and Shibani Varma Kapur have reached an amicable resolution through mediation facilitated by former Supreme Court judge Justice Kurian Joseph. The court has directed parties to implement the agreed terms.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/supreme-court-orders-execution-of-settlement-in-ardee-group-family-dispute/131592772?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-36582/131592772.cms?width=150&height=112", "tag": "regulatory"}]}
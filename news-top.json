{"updated_at": {"date": {"d": "26", "m": "05", "Y": "2026"}, "time": {"H": "07", "M": "33", "S": "51"}}, "news": [{"title": "NGT bench forms panel to probe illegal sand mining in Balasore", "para": "The National Green Tribunal has formed a joint committee to investigate allegations of illegal sand mining on the Subarnarekha river in Odisha's Balasore district. The committee, comprising representatives from district administration, SEIAA, and OSPCB, will submit a report within four weeks. This action follows a petition by local residents concerned about environmental degradation and revenue loss.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/ngt-bench-forms-panel-to-probe-illegal-sand-mining-in-balasore/131322993?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-225856/131322993.cms?width=150&height=112", "tag": "allied-industries"}, {"title": "Government adopts category-based land valuation in Taleigao", "para": "Goa's revenue department has replaced its uniform land valuation system with a category-based approach, piloting the change in Taleigao. This new methodology assigns different minimum land rates to plots within a village based on location and amenities, aiming to address inconsistencies and revenue loss from the previous uniform rate system.", "href": "https://realty.economictimes.indiatimes.com/news/industry/taleigao-implements-revolutionary-category-based-land-valuation-system/131322970?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-189632/131322970.cms?width=150&height=112", "tag": "industry"}, {"title": "Telangana government secures \u20b913,600 crore refinancing from IRFC for Hyderabad Metro Rail", "para": "Hyderabad Metro Rail has secured a significant financial boost with a Rs 13,600 crore refinancing agreement from IRFC. This deal aims to alleviate the project's debt burden and support future expansion, reinforcing the state government's commitment to enhancing public transport in the rapidly growing city. The loan will be repaid over 20 years.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/telangana-government-secures-13600-crore-refinancing-for-hyderabad-metro-rail-project/131320994?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1180038/131320994.cms?width=150&height=112", "tag": "infrastructure"}]}
{"updated_at": {"date": {"d": "11", "m": "04", "Y": "2026"}, "time": {"H": "06", "M": "46", "S": "47"}}, "news": [{"title": "Greater Noida looks for company to build logistics park in Dadri", "para": "Greater Noida Industrial Development Authority is appointing a developer for a 174-acre multi-modal logistics park in Kappa-II. Strategically located near Noida International Airport and freight corridors, the facility aims to boost the region's industrial hub status and reduce logistics costs for businesses.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/greater-noidas-new-logistics-park-a-174-acre-development-to-boost-industrial-growth/130184267?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-137016/130184267.cms?width=150&height=112", "tag": "allied-industries"}, {"title": "Ghaziabad development body now requires tree plantation for all new plot approvals", "para": "Ghaziabad Development Authority has mandated tree plantation based on plot size to enhance the city's green cover. New rules require land earmarked for planting to be shown on maps for approval, with security deposits refunded upon satisfactory plantation. This initiative aims to combat severe air pollution, as Ghaziabad was recently identified as India's most polluted city.", "href": "https://realty.economictimes.indiatimes.com/news/industry/ghaziabad-mandatory-tree-plantation-for-layout-approval-a-green-initiative/130183935?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-124168/130183935.cms?width=150&height=112", "tag": "industry"}, {"title": "Chandigarh administration clears FAR hike to cut flat prices, allow six floors", "para": "Chandigarh administration has increased the permissible Floor Area Ratio (FAR) to 2.4 for the Sector 53 housing project, allowing buildings up to six floors. This move aims to boost housing affordability by increasing the number of dwelling units and reducing per-unit costs. The revision is expected to soften prices for buyers, with further relaxations under consideration for other areas.", "href": "https://realty.economictimes.indiatimes.com/news/industry/chandigarh-administration-approves-far-hike-to-make-housing-more-affordable/130183834?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-200860/130183834.cms?width=150&height=112", "tag": "industry"}]}
{"updated_at": {"date": {"d": "21", "m": "05", "Y": "2026"}, "time": {"H": "17", "M": "48", "S": "44"}}, "news": [{"title": "MHADA reviews progress of housing projects in Kalyan taluka", "para": "MHADA vice-president and CEO Sanjeev Jaiswal reviewed the progress of housing projects being developed by the Konkan Housing and Area Development Board at Khoni, Shirdhon, Gotheghar and Bhandarli in Thane district. The projects include large-scale housing for economically weaker and low-income groups, along with shops and civic amenities.", "href": "https://realty.economictimes.indiatimes.com/news/industry/mhada-accelerates-housing-development-in-kalyan-taluka/131248232?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-84250/131248232.cms?width=150&height=112", "tag": "industry"}, {"title": "UP-RERA asks banks to enforce revised norms for real estate project accounts", "para": "UP-RERA has asked banks and financial institutions to follow revised operational guidelines for RERA-registered project accounts, including a mandatory three-account system, restrictions on liens, tighter withdrawal norms and quarterly disclosures of project finance. The authority said the guidelines are aimed at preventing diversion of homebuyer funds and improving monitoring of real estate projects.", "href": "https://realty.economictimes.indiatimes.com/news/rera/up-rera-imposes-new-banking-norms-for-real-estate-project-accounts-to-safeguard-homebuyer-interests/131248172?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-88178/131248172.cms?width=150&height=112", "tag": "rera"}, {"title": "MHADA starts allotment of 827 rehab units in Worli BDD Chawl redevelopment project", "para": "MHADA has started issuing allotment letters and possession of rehabilitation tenements in the first rehab building of the Worli BDD Chawl redevelopment project. On the first day, 41 eligible residents were issued allotment letters and 36 residents who completed documentation were given possession of their units.", "href": "https://realty.economictimes.indiatimes.com/news/residential/mhada-launches-allotment-of-827-rehabilitation-units-in-worli-bdd-chawl-redevelopment/131248132?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-37564/131248132.cms?width=150&height=112", "tag": "residential"}]}
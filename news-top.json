{"updated_at": {"date": {"d": "02", "m": "06", "Y": "2026"}, "time": {"H": "08", "M": "17", "S": "34"}}, "news": [{"title": "Don\u2019t rush to raze illegal buildings: West Bengal CM", "para": "Chief Minister Suvendu Adhikari has cautioned the Kolkata Municipal Corporation's buildings department against hasty demolitions without prior notice. He emphasized a careful approach, especially for buildings occupied by economically backward sections, urging adherence to legal procedures and opportunities for regularization of minor violations.", "href": "https://realty.economictimes.indiatimes.com/news/industry/west-bengal-cm-urges-caution-in-demolishing-illegal-buildings-to-protect-residents/131454426?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-31114/131454426.cms?width=150&height=112", "tag": "industry"}, {"title": "Chandigarh administration to auction 10 residential sites from June 2", "para": "Chandigarh administration is set to e-auction 10 residential plots ranging from 100 to 502 square yards later this month. Applications and earnest money deposits are open from June 2 to June 23, with reserve prices between Rs 3.3 crore and Rs 16.5 crore. The auction process will conclude by June 29.", "href": "https://realty.economictimes.indiatimes.com/news/residential/chandigarh-to-auction-10-residential-plots-key-details-and-bidding-process/131454182?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-224838/131454182.cms?width=150&height=112", "tag": "residential"}, {"title": "SC pulls up Jaipur development body over delay in action on commercial use of residential areas", "para": "The Supreme Court has severely criticized the Jaipur Development Authority (JDA) for its non-compliance with court directives regarding commercial establishments in residential areas. The JDA failed to appear or submit an affidavit detailing actions taken after surveys, despite ongoing resident complaints. The court emphasized the planning authority's accountability for enforcing town planning norms and protecting residential zones.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/supreme-court-rebukes-jaipur-development-authority-over-residential-area-violations/131454154?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-2067238/131454154.cms?width=150&height=112", "tag": "regulatory"}]}
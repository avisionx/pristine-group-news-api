{"updated_at": {"date": {"d": "26", "m": "05", "Y": "2026"}, "time": {"H": "14", "M": "35", "S": "03"}}, "news": [{"title": "Property tax sop for business spaces if free parking offered: Ahmedabad civic body", "para": "Ahmedabad Municipal Corporation is offering property tax exemptions to commercial establishments that open their parking facilities to the public free of charge. This initiative aims to reduce roadside parking and ease city traffic congestion. Participating businesses must consent via a form, manage parking through the AmadaPark app, and install signage. Failure to comply will disqualify them from the tax benefit.", "href": "https://realty.economictimes.indiatimes.com/news/industry/ahmedabad-offers-property-tax-exemptions-for-businesses-providing-free-parking/131323161?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-80944/131323161.cms?width=150&height=112", "tag": "industry"}, {"title": "Residents push for Kirti Nagar-Palam metro extension till Dwarka Expressway", "para": "Residents of new Gurgaon and Dwarka sectors are demanding an extension of the Kirti Nagar-Palam Metro corridor to Dwarka and Dwarka Expressway due to increasing traffic and inadequate public transport. They seek better metro and bus connectivity to ease congestion on major roads and reduce reliance on private vehicles.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/push-for-kirti-nagar-palam-metro-extension-to-alleviate-traffic-between-gurgaon-and-dwarka/131323094?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-273166/131323094.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "NGT bench forms panel to probe illegal sand mining in Balasore", "para": "The National Green Tribunal has formed a joint committee to investigate allegations of illegal sand mining on the Subarnarekha river in Odisha's Balasore district. The committee, comprising representatives from district administration, SEIAA, and OSPCB, will submit a report within four weeks. This action follows a petition by local residents concerned about environmental degradation and revenue loss.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/ngt-bench-forms-panel-to-probe-illegal-sand-mining-in-balasore/131322993?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-225856/131322993.cms?width=150&height=112", "tag": "allied-industries"}]}
{"updated_at": {"date": {"d": "13", "m": "03", "Y": "2026"}, "time": {"H": "10", "M": "24", "S": "05"}}, "news": [{"title": "Investors allege \u20b91.6 crore fraud in WTC GIFT City scheme", "para": "CID (Crime) has registered a complaint alleging financial fraud exceeding Rs 1.56 crore in a GIFT City investment scheme. Investors were promised high monthly returns and a buyback guarantee for commercial units, but their funds were allegedly not repaid after payments stopped in September 2022. Post-dated cheques for repayment were dishonoured, prompting an investigation into the alleged fraud.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/investors-claim-16-crore-fraud-in-gift-city-commercial-scheme/129534337?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-41204/129534337.cms?width=150&height=112", "tag": "commercial"}, {"title": "Illegal colonies, walls and sheds razed by DTCP in Gurugram", "para": "The Department of Town and Country Planning (DTCP) intensified its campaign against illegal constructions this week, conducting demolition drives in Sadhrana, Bhondsi, and Sector 89. Authorities razed unauthorized colonies and structures, including foundations, boundary walls, and sheds, to curb encroachment and protect buyers from misleading developments. The action aimed to prevent further illegal plotting and sale of land.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/gurugram-dtcp-demolishes-illegal-colonies-and-structures-in-major-crackdown/129534136?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-38082/129534136.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Magistrate\u2019s court to hear \u20b9140 crore Guruashish cheating case", "para": "A special court in Mumbai transferred a Rs 140 crore cheating and conspiracy case against Guruashish Construction and its directors to a magistrate's court. The CBI found no evidence of public servant involvement, leading the special court to state it lacked jurisdiction to proceed with the matter against private individuals alone.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/major-140-crore-cheating-case-against-guruashish-construction-transferred-to-magistrates-court/129534059?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-39596/129534059.cms?width=150&height=112", "tag": "regulatory"}]}
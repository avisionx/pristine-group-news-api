{"updated_at": {"date": {"d": "02", "m": "11", "Y": "2025"}, "time": {"H": "16", "M": "09", "S": "48"}}, "news": [{"title": "Nagpur civic body cracks down on property tax defaulters with tech-driven warrant system", "para": "Nagpur Municipal Corporation is intensifying property tax recovery, targeting chronic defaulters with a new automated warrant alert system.  Leveraging India Post's Proof of Delivery, the NMC ensures invoices reach owners.  Those ignoring confirmed deliveries now face immediate SMS alerts for warrant execution, signaling a shift to strict enforcement to recover over Rs1,000 crore in arrears.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/nagpur-municipal-corporation-implements-tech-driven-crackdown-on-property-tax-defaulters/125033709?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-30354/125033709.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Mangaluru: \u20b9135 crore tender floated for tech park under PPP model", "para": "Mangaluru, the 'Silicon Beach of India', is set to get its first purpose-built tech park. Karnataka State Electronics Development Corporation (KEONICS) has floated a Rs 135 crore tender for the project, which will be developed under a public-private partnership (PPP) model.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/mangaluru-launches-135-crore-tech-park-tender-to-boost-job-creation-and-sustainability/125033558?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-13510/125033558.cms?width=150&height=112", "tag": "commercial"}, {"title": "NGT directs MoEFCC to review environmental clearance for Gurugram housing project", "para": "The National Green Tribunal has stepped in, instructing the Union Environment Ministry to reassess the environmental clearance for a proposed housing project expansion in Gurugram. This decision arises from challenges brought forth by a resident welfare group.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ngt-directs-moefcc-to-review-environmental-clearance-for-gurugram-housing-project/125032887?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-46782/125032887.cms?width=150&height=112", "tag": "regulatory"}]}
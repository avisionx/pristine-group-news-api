{"updated_at": {"date": {"d": "03", "m": "05", "Y": "2026"}, "time": {"H": "16", "M": "34", "S": "59"}}, "news": [{"title": "Visakhapatnam civic body collects \u20b9230 crore property tax in April 2026", "para": "Greater Visakhapatnam Municipal Corporation (GVMC) witnessed a significant 50% surge in property and vacant land tax collections for April, reaching Rs 230 crore. This increase was driven by a 5% early bird rebate and a government waiver on interest for outstanding dues paid by April 30, encouraging timely payments.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/greater-visakhapatnam-municipal-corporation-sees-50-surge-in-property-tax-collection/130733447?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-108366/130733447.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Hostels & PGs in Tamil Nadu to increase rent by 10% from May 5, as commercial LPG cylinder prices rise", "para": "Hostel and PG rents in Tamil Nadu are set to increase by approximately 10% starting May 5. Operators cite a significant surge in commercial LPG cylinder prices, forcing them to adjust tariffs. Some establishments have also reduced food services or increased maintenance fees due to rising operational costs.", "href": "https://realty.economictimes.indiatimes.com/news/residential/tamil-nadu-hostels-and-pgs-to-hike-rent-by-10-amid-rising-lpg-costs/130733261?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-78718/130733261.cms?width=150&height=112", "tag": "residential"}, {"title": "Cement companies in Meghalaya imported nearly three lakh MT of coal without valid papers: HC-appointed panel", "para": "A high court committee report reveals two Meghalaya cement companies violated norms transporting over 2.93 lakh metric tonnes of coal. The companies moved the fuel without mandatory approvals and failed to file returns. Crucial documents were also missing. The committee recommended strict enforcement and improved tracking systems to curb illegal coal movement across the state.", "href": "https://realty.economictimes.indiatimes.com/news/cement/meghalaya-cement-companies-illegally-transported-coal-hc-report-exposes-multiple-violations/130733201?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-205516/130733201.cms?width=150&height=112", "tag": "cement"}]}
{"updated_at": {"date": {"d": "19", "m": "04", "Y": "2026"}, "time": {"H": "20", "M": "24", "S": "23"}}, "news": [{"title": "NGT forms committee to investigate encroachments at Shahpura lake in Bhopal", "para": "The National Green Tribunal has formed a committee to investigate alleged encroachments and illegal constructions around Bhopal's Shahpura lake. The tribunal is concerned about untreated water discharge, obstructed drainage, and the lake's deteriorating water quality, which is unsuitable for use. This action follows a petition highlighting the ecological damage despite ongoing beautification efforts.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/ngt-launches-investigation-into-encroachments-at-shahpura-lake-in-bhopal/130367013?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-189580/130367013.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Andhra Pradesh government speeds up LRS clearances ahead of April 23 deadline", "para": "The Andhra Pradesh government is pushing to approve layout regularisation applications quickly. This scheme aims to bring unauthorized layouts into the legal framework. The deadline is approaching next week. Officials are directed to clear eligible applications without delay. This initiative seeks to boost state revenue and promote planned urban development. Over 61,000 applications have been received.", "href": "https://realty.economictimes.indiatimes.com/news/industry/andhra-pradesh-government-urges-urgent-lrs-clearances-before-april-23-deadline/130366594?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-111522/130366594.cms?width=150&height=112", "tag": "industry"}, {"title": "Maharashtra to roll out 60 private-run property registration centres from July", "para": "Maharashtra's registration department is launching 60 private centres by July, modelled on passport offices, to speed up property registrations. These centres will offer enhanced amenities for a processing fee of up to Rs 5,217, operating alongside existing government offices.", "href": "https://realty.economictimes.indiatimes.com/news/industry/maharashtra-launches-60-private-property-registration-centres-to-enhance-efficiency/130366718?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-96478/130366718.cms?width=150&height=112", "tag": "industry"}]}
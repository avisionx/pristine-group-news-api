{"updated_at": {"date": {"d": "14", "m": "06", "Y": "2026"}, "time": {"H": "11", "M": "47", "S": "39"}}, "news": [{"title": "Odisha government to introduce new act soon as it plans major shift in urban rental housing", "para": "Odisha is set to introduce the draft Odisha Urban Area Rent Control Act, 2026, replacing the 1967 act. The legislation mandates written agreements, caps security deposits, and establishes rent authorities and courts for speedy dispute resolution, aiming to balance tenant and landlord rights.", "href": "https://realty.economictimes.indiatimes.com/news/industry/odisha-to-revamp-urban-rental-housing-with-new-rent-control-act/131716191?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-154374/131716191.cms?width=150&height=112", "tag": "industry"}, {"title": "Panchkula civic body to discuss property tax waiver in its first General House meeting", "para": "Panchkula's first General House meeting on June 16 will focus on key development agendas, including making Ward No. 4 a model cleanliness ward and implementing a property tax amnesty to recover \u20b9100 crore in dues. The meeting will also address civic infrastructure upgrades, waterlogging solutions, and broader development goals like recreation centers and sports facilities.", "href": "https://realty.economictimes.indiatimes.com/news/industry/panchkula-municipal-corporation-to-discuss-major-property-tax-waiver-and-cleanliness-initiatives-in-upcoming-meeting/131716148?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-95998/131716148.cms?width=150&height=112", "tag": "industry"}, {"title": "Gurugram: DTCP to resume crackdown on illegal builds in DLF phases next week", "para": "The Department of Town and Country Planning (DTCP) in Gurugram is set to resume large-scale enforcement against illegal constructions in DLF Phase 3 and other phases. Following a high court order, over 3,500 properties are now eligible for action, targeting extensions, stilt parking violations, and unauthorized commercial use.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/dtcps-major-crackdown-on-illegal-constructions-resumes-in-gurugrams-dlf-phases/131716130?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-210968/131716130.cms?width=150&height=112", "tag": "infrastructure"}]}
{"updated_at": {"date": {"d": "15", "m": "05", "Y": "2026"}, "time": {"H": "19", "M": "13", "S": "36"}}, "news": [{"title": "BuzzWorks forays in Mysuru with 16,000 sq ft office space", "para": "BuzzWorks, Brigade Group's managed office and co-working division, has launched a 16,000 sq ft center in Mysuru, offering over 500 seats. This expansion is part of a broader multi-city growth strategy for the financial year, with further developments planned in Bengaluru and a new entry into Chennai.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/buzzworks-expands-presence-in-mysuru-with-new-16000-sq-ft-office/131116969?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-68264/131116969.cms?width=150&height=112", "tag": "commercial"}, {"title": "India\u2019s average residential rents rise 14% in Jan-Mar 2026: Magicbricks", "para": "India\u2019s residential rental market saw average rents rise 14% year-on-year and 2% sequentially in January-March 2026, according to Magicbricks. While demand grew marginally, supply increased at a faster pace, led by new completions and handovers in peripheral markets across major cities.", "href": "https://realty.economictimes.indiatimes.com/news/residential/india-sees-14-surge-in-average-residential-rents-in-q1-2026/131113824?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-62510/131113824.cms?width=150&height=112", "tag": "residential"}, {"title": "Grade-A office absorption rises 5% to 13.5 million sq ft in Q1 2026: Anarock", "para": "Net absorption of Grade A office space across the top seven cities rose five per cent year-on-year to 13.5 million sq ft in Q1 2026, driven by Bengaluru, Hyderabad and Chennai, according to Anarock. Overall vacancy declined to 15.5 per cent from 16.3 per cent a year earlier, while GCCs continued to account for a rising share of office leasing demand.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/office-space-demand-soars-135-million-sq-ft-absorbed-in-q1-2026/131112888?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-168582/131112888.cms?width=150&height=112", "tag": "commercial"}]}
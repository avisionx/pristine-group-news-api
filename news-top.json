{"updated_at": {"date": {"d": "14", "m": "04", "Y": "2026"}, "time": {"H": "09", "M": "07", "S": "02"}}, "news": [{"title": "Waste charges stall Bengaluru apartments' property tax payments", "para": "Bengaluru apartment dwellers are delaying property tax payments due to confusion over solid waste management charges.  Complexes generating over 100kg of waste daily are eligible for exemption but face a complex declaration process. Residents lack data on waste generation and fear penalties for incorrect submissions, urging authorities for clearer guidelines and a simplified system.", "href": "https://realty.economictimes.indiatimes.com/news/industry/waste-charges-stall-bengaluru-apartments-property-tax-payments/130249759?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-132056/130249759.cms?width=150&height=112", "tag": "industry"}, {"title": "Indore civic body gets cracking on illegal colonies, 16 row houses razed", "para": "The crackdown primarily focused on Zone 4. In Anjani Nagar, four row houses illegally constructed near a drain were completely removed, while at Jagdish Nagar in Banganga area, removal operations targeted 12 row houses. Officials revealed that six of them were nearly complete with finishing work underway, while the remaining six were under construction.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/indore-civic-body-gets-cracking-on-illegal-colonies-16-row-houses-razed/130249739?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-104456/130249739.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "No capital gains if flat's sale price equals purchase cost: ITAT", "para": "The Income Tax Appellate Tribunal ruled that no capital gains tax applies when a property's sale price equals its purchase cost. The tribunal allowed a taxpayer's appeal, deleting a Rs 42.5 lakh addition by the tax department. This decision was based on the identical purchase and sale values and a similar ruling in the co-owner's case.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/no-capital-gains-if-flats-sale-price-equals-purchase-cost-itat/130249543?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-106642/130249543.cms?width=150&height=112", "tag": "regulatory"}]}
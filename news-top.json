{"updated_at": {"date": {"d": "20", "m": "06", "Y": "2026"}, "time": {"H": "22", "M": "56", "S": "36"}}, "news": [{"title": "Five private-run property registration hubs to open in August, one in Pune", "para": "Maharashtra's registration department is launching five private model sub-registrar offices in August, including one in Pune, as part of a plan for 60 such centers via public-private partnership. These modern facilities, modeled on Passport Seva Kendras, will offer improved infrastructure and services for an additional fee. While private operators manage facilities, government officials retain all statutory powers, ensuring continued regulatory control.", "href": "https://realty.economictimes.indiatimes.com/news/industry/launch-of-private-property-registration-hubs-in-pune-and-maharashtra/131870221?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-259125/131870221.cms?width=150&height=112", "tag": "industry"}, {"title": "Bhopal: EOW books Hilltop Society office-bearers in multi-crore plot fraud case", "para": "Bhopal's Economic Offences Wing has filed a fraud case against office-bearers of the Hilltop Housing Cooperative Society. For over four decades, the society allegedly collected crores from hundreds of members for promised plots but failed to deliver possession. Investigations revealed evidence of cheating, forgery, and criminal conspiracy, with members facing years of delays and alleged manipulation of records, even after land acquisition by the MP Housing Board.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/bhopal-housing-society-scandal-office-bearers-charged-in-multi-crore-fraud-case/131870132?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-532084/131870132.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Institutional ownership narrows office supply as outright demand holds up", "para": "India\u2019s office real estate market is shifting towards a leasing-led model, with developers, REITs and institutional investors increasingly retaining assets instead of selling them, reducing the availability of premium office spaces for outright purchase.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/indias-office-market-demand-surges-amidst-limited-supply-of-premium-assets/131870079?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1205949/131870079.cms?width=150&height=112", "tag": "commercial"}]}
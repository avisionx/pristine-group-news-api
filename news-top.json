{"updated_at": {"date": {"d": "31", "m": "05", "Y": "2026"}, "time": {"H": "20", "M": "45", "S": "31"}}, "news": [{"title": "With 283 \u2018dangerous\u2019 buildings, Ulhasnagar braces for rain fury", "para": "Ulhasnagar Municipal Corporation's pre-monsoon survey identified 283 dangerous buildings, with six declared extremely hazardous and requiring immediate evacuation. A significant number of structures need major or urgent repairs, and 144 lack essential structural audit reports, raising concerns about their stability as monsoon approaches.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/ulhasnagars-monsoon-danger-283-buildings-at-risk-of-collapse/131420855?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-13822/131420855.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Chandigarh administration may allow industrial plot fragmentation for four kanal units", "para": "Chandigarh's UT administration has proposed allowing fragmentation of industrial plots measuring 4 kanal and above, with a maximum of three subdivisions and a minimum plot width of 50 feet. This move aims to ensure regulated development, preventing colony-like layouts and mandating adequate parking. Revised zoning plans will be required before construction.", "href": "https://realty.economictimes.indiatimes.com/news/industry/chandigarh-administration-to-permit-fragmentation-of-industrial-plots-of-4-kanal-or-more/131420776?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-189632/131420776.cms?width=150&height=112", "tag": "industry"}, {"title": "Chennai's town planning department to issue building permits within 27 days", "para": "Chennai's town planning department will now issue building permits within 27 days, aiming to curb corruption and delays. Officials are barred from summoning applicants, with all processes, including payments and clarifications, moving online. This move ensures time-bound, transparent service delivery for the public, streamlining approvals for various building types.", "href": "https://realty.economictimes.indiatimes.com/news/industry/chennai-government-streamlines-building-permit-process-to-just-27-days/131420508?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-46628/131420508.cms?width=150&height=112", "tag": "industry"}]}
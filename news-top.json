{"updated_at": {"date": {"d": "07", "m": "04", "Y": "2026"}, "time": {"H": "08", "M": "50", "S": "15"}}, "news": [{"title": "Kalaburagi district posts record 89.8% property tax recovery", "para": "Kalaburagi district achieved a historic 89.8% property tax recovery, its highest in nine years, collecting Rs 33.4 crore by March 31, 2026. Strict measures by the zilla panchayat CEO, including doorstep collections and action against non-compliant officials, significantly boosted revenue, strengthening village panchayats financially.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/kalaburagi-district-achieves-record-898-property-tax-recovery/130080033?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-108238/130080033.cms?width=150&height=112", "tag": "regulatory"}, {"title": "KREEVA to invest \u20b9350-400 crore to develop residential project in Gurugram", "para": "Kreeva, Kanodia Group's real estate division, will invest \u20b9350-400 crore in a Gurugram housing project. The development will span three acres and offer around 200 residences. This project marks the company's entry into multi-generational housing. Construction is expected to begin by the end of the first quarter of fiscal year 2027.", "href": "https://realty.economictimes.indiatimes.com/news/residential/kreeva-to-invest-350-400-crore-to-develop-residential-project-in-gurugram/130080336?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-91010/130080336.cms?width=150&height=112", "tag": "residential"}, {"title": "Bhubaneswar civic body to survey residential buildings misused for commercial purposes", "para": "The Bhubaneswar Municipal Corporation will conduct a comprehensive survey to identify residential buildings misused for commercial purposes, following a Supreme Court directive. Ward-level teams will inspect properties operating as offices, shops, or clinics without permission. This action addresses long-standing resident complaints about traffic, pollution, and infrastructure strain.", "href": "https://realty.economictimes.indiatimes.com/news/residential/bhubaneswar-municipal-corporation-launches-survey-on-misused-residential-buildings/130079983?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-20204/130079983.cms?width=150&height=112", "tag": "residential"}]}
{"updated_at": {"date": {"d": "23", "m": "03", "Y": "2026"}, "time": {"H": "04", "M": "15", "S": "51"}}, "news": [{"title": "Goa consumer commission orders Dimension Builders to form flat owners' society", "para": "A builder must form a society for flat owners in Dimension Residency within three months. If the builder fails, residents can form it themselves. This order comes after a flat owner complained about defects. The commission noted the builder's failure to address issues. Compensation was denied due to the complaint being filed late.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/goa-commission-orders-dimension-builders-to-establish-flat-owners-society-following-defects/129741428?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-34248/129741428.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Bombay HC quashes DRT's stay order on post-sale process of mortgaged flat in Mumbai auctioned by bank", "para": "The Bombay High Court has overturned a Debt Recovery Tribunal order that halted the sale of a south Mumbai flat. The court noted a concerning trend where borrowers delay action until auctions are finalized. They then use insolvency proceedings to stall possession. This ruling provides relief to auction purchasers.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/bombay-hc-overturns-drt-stay-order-on-auctioned-flat-empowers-buyers/129741287?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-202254/129741287.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Global investors eye GIFT City amid West Asia conflict", "para": "Rising geopolitical tensions in West Asia are prompting global investors and NRIs to reassess their Dubai exposure, leading to increased inquiries for India's GIFT City. Investors are seeking regulatory stability and proximity to growth markets, driving a 'dual-hub' strategy rather than a complete relocation from Dubai.", "href": "https://realty.economictimes.indiatimes.com/news/industry/investors-turn-to-gift-city-as-west-asia-tensions-rise/129741263?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-1375095/129741263.cms?width=150&height=112", "tag": "industry"}]}
{"updated_at": {"date": {"d": "12", "m": "04", "Y": "2026"}, "time": {"H": "07", "M": "01", "S": "27"}}, "news": [{"title": "Hyderabad: 861 acres secured, apartment blocks, farmhouse razed in Ameenpur", "para": "HYDRAA launched a massive operation, securing 861 acres of prime government land in Ameenpur, Sangareddy, valued at over Rs 15,000 crore. The crackdown involved demolishing major structures, including an apartment building and a farmhouse, amidst allegations of insufficient notice to tenants. Authorities stated due process was followed, targeting long-standing encroachments linked to alleged encroacher MA Mukheem.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/major-land-crackdown-in-hyderabad-861-acres-secured-amid-tenant-panic/130202630?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-172668/130202630.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Punjab: PPCB shields homebuyers from builders' environmental violations", "para": "The Punjab Pollution Control Board will now allow sale deeds and electricity connections for homebuyers in projects with environmental violations. This move aims to protect innocent buyers from penalties while continuing strict action, including prosecution, against defaulting real estate developers. The board emphasized that access to electricity is a basic necessity linked to the Right to Life.", "href": "https://realty.economictimes.indiatimes.com/news/residential/punjab-ppcb-protects-homebuyers-from-builders-environmental-violations/130202540?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-249992/130202540.cms?width=150&height=112", "tag": "residential"}, {"title": "Andhra Pradesh to fund Amaravati debt from land sales, not taxes: Municipal minister", "para": "Andhra Pradesh Minister P Narayana revealed plans to alleviate Amaravati's capital debts through the sale of 5,000 acres of land. Each acre is projected to yield Rs 20 crore upon the project's finalization. He underscored the TDP government's proactive investments and calls for tenders.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/andhra-pradesh-to-fund-amaravati-debt-from-land-sales-not-taxes-municipal-minister/130202506?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-64320/130202506.cms?width=150&height=112", "tag": "infrastructure"}]}
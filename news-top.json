{"updated_at": {"date": {"d": "10", "m": "11", "Y": "2025"}, "time": {"H": "08", "M": "15", "S": "34"}}, "news": [{"title": "Goa: GIDC pitches 50% fee waiver for online building nods", "para": "Goa Industrial Development Corporation (GIDC) is launching a new initiative to boost digital adoption and revive defunct industrial units.  Starting November 15, a 50% waiver on construction licence fees will be offered for one year on applications submitted through the Online Building Plan Approval System (OBPAS). This aims to accelerate project clearances and encourage productive use of industrial land.", "href": "https://realty.economictimes.indiatimes.com/news/technology/goa-gidc-offers-50-waiver-on-building-license-fees-to-boost-industrial-growth/125214605?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-15838/125214605.cms?width=150&height=112", "tag": "technology"}, {"title": "TCP must inform us of construction plans exceeding 20,000 sq meters: Goa-SEIAA", "para": "Goa's environmental authority now requires planning departments to report building plan approvals exceeding 20,000 sqm. This move aims to ensure projects have necessary environmental clearances before construction begins. The authority will also inform departments upon approving such projects, streamlining the verification process.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/goa-seiaa-mandates-tcp-to-notify-on-large-construction-projects-over-20000-sq-meters/125214333?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-257492/125214333.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Navi Mumbai civic body appeals residents to conduct audit of buildings older than 30 years", "para": "Navi Mumbai Municipal Corporation declared 513 buildings dangerous, urging residents to conduct structural audits for buildings over 30 years old by March 31, 2026. Failure to comply, as mandated by the Maharashtra Municipal Corporation Act, can result in significant fines. Residents are strongly advised to vacate dangerous structures to prevent potential loss of life and property.", "href": "https://realty.economictimes.indiatimes.com/news/industry/navi-mumbai-pushes-for-urgent-structural-audits-of-30-year-old-buildings-to-ensure-safety/125214134?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-73978/125214134.cms?width=150&height=112", "tag": "industry"}]}
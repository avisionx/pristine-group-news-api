{"updated_at": {"date": {"d": "16", "m": "06", "Y": "2026"}, "time": {"H": "14", "M": "49", "S": "48"}}, "news": [{"title": "ED searches at 17 locations in corporate insolvency process case", "para": "The Enforcement Directorate conducted searches across Maharashtra and Delhi in a money laundering probe linked to alleged irregularities in a corporate insolvency resolution process. The investigation targets Suraksha Asset Reconstruction Company, Suraksha Realty, Khyati Realtors, their associates, and a former YES Bank employee, focusing on fraudulent loan grants and asset takeovers.", "href": "https://realty.economictimes.indiatimes.com/news/regulatory/ed-raids-17-locations-in-major-corporate-insolvency-case-linked-to-yes-bank/131773193?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-205292/131773193.cms?width=150&height=112", "tag": "regulatory"}, {"title": "Kalki Koechlin sells apartment in Mumbai for \u20b92.55 crore", "para": "Actress Kalki Koechlin has sold her Mumbai apartment in Varsova Kiran Co-operative Housing Society for \u20b92.55 crore. Purchased in 2015 for \u20b91.95 crore, the sale reflects an appreciation of approximately \u20b960 lakh over a decade. The transaction, registered in April 2026, saw a stamp duty payment of \u20b916.08 lakh.", "href": "https://realty.economictimes.indiatimes.com/news/residential/kalki-koechlin-sells-mumbai-apartment-for-255-crore-a-profitable-investment/131767135?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-141974/131767135.cms?width=150&height=112", "tag": "residential"}, {"title": "From Krishna Curve to Krishna CONIQ: Redefining the future of urban retail destinations", "para": "Krishna United Group is transforming Mumbai's Linking Road into a lifestyle hub. Following the success of Krishna Curve, the company is launching Krishna CONIQ. This ambitious project integrates retail, dining, entertainment, and office spaces. It aims to create an immersive experience engaging all five senses. Krishna CONIQ represents the future of urban retail and lifestyle destinations in India.", "href": "https://realty.economictimes.indiatimes.com/news/brand-connect-initiative/krishna-coniq-revolutionizing-urban-retail-with-experience-driven-design/131762749?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-14634/131762749.cms?width=150&height=112", "tag": "brand-connect-initiative"}]}
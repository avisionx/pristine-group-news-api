{"updated_at": {"date": {"d": "27", "m": "04", "Y": "2026"}, "time": {"H": "01", "M": "28", "S": "52"}}, "news": [{"title": "Over 140 to get \u20b950 lakh house repair aid in Ludhiana\u2019s Ward 72", "para": "Ludhiana residents from weaker sections will receive financial aid for home repairs. The Rangla Punjab scheme will help 144 beneficiaries fix dilapidated roofs and other damages. Each recipient gets Rs 35,000. This initiative is part of a larger development plan for urban areas. Bank details are being collected for prompt payments.", "href": "https://realty.economictimes.indiatimes.com/news/residential/state-government-to-provide-50-lakh-in-home-repair-aid-to-144-weaker-section-families-in-ludhiana/130533247?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-36262/130533247.cms?width=150&height=112", "tag": "residential"}, {"title": "Navi Mumbai civic body flags 500 buildings as unsafe, issues vacate notices", "para": "Navi Mumbai Municipal Corporation has declared 500 buildings dangerous, issuing notices for residents to vacate. This action follows a survey and aligns with high court orders. The civic body emphasizes mandatory structural audits for older buildings and requires permission for repairs, holding societies and flat owners accountable for accidents.", "href": "https://realty.economictimes.indiatimes.com/news/industry/navi-mumbai-declares-500-buildings-unsafe-urgent-evacuation-notices-issued/130533029?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-75290/130533029.cms?width=150&height=112", "tag": "industry"}, {"title": "Bengaluru property owners can now download e-khatas online", "para": "Bengaluru property owners can now download e-khatas online via the GBA's e-Aasthi platform, eliminating office visits.  This digital initiative, accessible with a SAS property tax ID, streamlines documentation for tax payments, loans, and transactions.  While provisional, it aims to cut red tape and corruption, with full legal validity requiring further steps like Aadhaar KYC and deed updates.", "href": "https://realty.economictimes.indiatimes.com/news/technology/bengaluru-residents-can-now-access-e-khatas-instantly-online/130532969?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-37134/130532969.cms?width=150&height=112", "tag": "technology"}]}
{"updated_at": {"date": {"d": "13", "m": "03", "Y": "2026"}, "time": {"H": "18", "M": "26", "S": "09"}}, "news": [{"title": "MHADA to push redevelopment of old layouts in Mumbai, Pune and Nashik", "para": "Maharashtra's real estate market is experiencing a remarkable transformation driven by the redevelopment of brownfield sites. The Maharashtra Housing and Area Development Authority (MHADA) is placing emphasis on revamping outdated housing schemes in key urban areas, notably Mumbai, Pune, and Nashik.", "href": "https://realty.economictimes.indiatimes.com/news/industry/mhada-to-push-redevelopment-of-old-layouts-in-mumbai-pune-and-nashik/129549735?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-130764/129549735.cms?width=150&height=112", "tag": "industry"}, {"title": "Investors allege \u20b91.6 crore fraud in WTC GIFT City scheme", "para": "CID (Crime) has registered a complaint alleging financial fraud exceeding Rs 1.56 crore in a GIFT City investment scheme. Investors were promised high monthly returns and a buyback guarantee for commercial units, but their funds were allegedly not repaid after payments stopped in September 2022. Post-dated cheques for repayment were dishonoured, prompting an investigation into the alleged fraud.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/investors-claim-16-crore-fraud-in-gift-city-commercial-scheme/129534337?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-41204/129534337.cms?width=150&height=112", "tag": "commercial"}, {"title": "Illegal colonies, walls and sheds razed by DTCP in Gurugram", "para": "The Department of Town and Country Planning (DTCP) intensified its campaign against illegal constructions this week, conducting demolition drives in Sadhrana, Bhondsi, and Sector 89. Authorities razed unauthorized colonies and structures, including foundations, boundary walls, and sheds, to curb encroachment and protect buyers from misleading developments. The action aimed to prevent further illegal plotting and sale of land.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/gurugram-dtcp-demolishes-illegal-colonies-and-structures-in-major-crackdown/129534136?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-38082/129534136.cms?width=150&height=112", "tag": "infrastructure"}]}
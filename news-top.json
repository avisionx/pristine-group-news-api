{"updated_at": {"date": {"d": "21", "m": "04", "Y": "2026"}, "time": {"H": "10", "M": "57", "S": "03"}}, "news": [{"title": "Manasum Senior Living plans to invest \u20b9150 crore to develop senior living project in Chennai", "para": "Manasum Senior Living is investing \u20b9150 crore in Chennai for The Madras Pavilion, a senior living project. This development will feature 92 villas and 36 apartments. The company also plans a \u20b9550 crore investment to expand its operations across South and West India.", "href": "https://realty.economictimes.indiatimes.com/news/residential/manasum-senior-living-plans-to-invest-150-crore-to-develop-senior-living-project-in-chennai/130414527?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-48820/130414527.cms?width=150&height=112", "tag": "residential"}, {"title": "Vadodara civic body's built homes fall apart in 20 years", "para": "Residents of Vadodara's JNNURM housing schemes are experiencing poor living conditions. Houses built for the economically weaker sections are showing signs of damage. Issues like water seepage and falling plaster have been reported. The Vadodara Municipal Corporation states the core structures are sound. They attribute problems to seepage and neglect by residents.", "href": "https://realty.economictimes.indiatimes.com/news/residential/vadodaras-jnnurm-housing-crisis-residents-face-deteriorating-conditions/130414214?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-139739/130414214.cms?width=150&height=112", "tag": "residential"}, {"title": "Government land worth \u20b930 crore freed from encroachment, 12 houses demolished in Indore", "para": "Indore district administration launched a significant anti-encroachment drive, reclaiming prime government land valued at approximately Rs 30 crore. Following collector Shivam Verma's orders, authorities demolished 12 illegally constructed houses spanning 30,000 square feet in Khajrana village. The administration has vowed to continue strict action against land encroachers.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/indore-administration-demolishes-12-illegal-houses-reclaims-30-crore-govt-land/130414083?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-87918/130414083.cms?width=150&height=112", "tag": "infrastructure"}]}
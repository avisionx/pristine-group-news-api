{"updated_at": {"date": {"d": "02", "m": "05", "Y": "2026"}, "time": {"H": "04", "M": "50", "S": "05"}}, "news": [{"title": "Pidilite Ventures to exit Buildnext via share swap with JSW One Platforms", "para": "Pidilite Industries' wholly-owned subsidiary Pidilite Ventures has entered into a share swap agreement with JSW One Platforms, under which it will transfer its stake in home design and project management firm Buildnext to JSW One in exchange for shares of the latter, while simultaneously investing up to \u20b922 crore more in Buildnext through convertible preference shares.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/pidilite-ventures-to-exit-buildnext-via-share-swap-with-jsw-one-platforms/130709671?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-35364/130709671.cms?width=150&height=112", "tag": "allied-industries"}, {"title": "Home interior startups lean on AI to shave costs, chase profits", "para": "India's home interior sector is turning to AI to combat high customer acquisition costs and operational expenses. Companies like Homelane and Livspace are leveraging AI to boost designer productivity and streamline operations, aiming for profitability amidst stiff competition from the unorganized sector.", "href": "https://realty.economictimes.indiatimes.com/news/allied-industries/ai-technology-revolutionizes-indias-home-interior-startups-amidst-challenges/130709442?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-51346/130709442.cms?width=150&height=112", "tag": "allied-industries"}, {"title": "Ludhiana improvement trust eyes \u20b9197 crore in auction for 18-year-abandoned ruin", "para": "Ludhiana Improvement Trust is attempting to sell a derelict 2.2-acre multi-storey building for \u20b9197 crore after an 18-year vacancy. The 77-unit complex, built for commercial and residential use, has been a symbol of administrative inertia, with past reuse proposals failing. Officials hope the current buoyant commercial real estate market will secure a buyer.", "href": "https://realty.economictimes.indiatimes.com/news/industry/ludhiana-improvement-trust-targets-197-crore-in-auction-for-long-abandoned-building/130709421?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-49104/130709421.cms?width=150&height=112", "tag": "industry"}]}
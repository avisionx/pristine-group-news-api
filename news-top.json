{"updated_at": {"date": {"d": "05", "m": "03", "Y": "2026"}, "time": {"H": "01", "M": "06", "S": "25"}}, "news": [{"title": "Modis Navnirman to redevelop residential society in Mumbai", "para": "Modis Navnirman will redevelop the New Chitra Co-operative Housing Society in Kandivali West. The existing 14-storey building will be demolished. A new commercial-residential tower will be constructed on the 2,300 sq meter plot. This project is expected to generate \u20b9160 crore in gross development value. Modis Navnirman is also developing another project in Borivali West.", "href": "https://realty.economictimes.indiatimes.com/news/industry/modis-navnirman-to-transform-kandivali-west-with-new-mixed-use-development/129035061?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-28680/129035061.cms?width=150&height=112", "tag": "industry"}, {"title": "Embassy REIT acquires 0.3 million sq ft office space in Bengaluru for \u20b9852 crore", "para": "Embassy Office Parks REIT has bought a Bengaluru office property for \u20b9852 crore. The deal involved acquiring Eleanor Realty Holdings India, which owns the Pinehurst building. This grade-A office space is fully leased to a global investment firm. The transaction was completed at a discount to independent valuations. PwC and Trilegal provided advisory services for the deal.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/embassy-reit-expands-portfolio-with-852-crore-bengaluru-office-acquisition/129033256?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-155718/129033256.cms?width=150&height=112", "tag": "commercial"}, {"title": "Focus of Ahmedabad development plan shifts to 2041", "para": "Ahmedabad Urban Development Authority is drafting a 20-year Development Plan (DP 2041), a departure from the traditional 10-year cycle, driven by the prospect of hosting the 2036 Olympics. This extended plan aims to transform Ahmedabad into a global metropolitan city, with special provisions for sports facilities and infrastructure development in surrounding villages.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/ahmedabad-shifts-to-ambitious-20-year-development-plan-aiming-for-2041-and-the-2036-olympics/129001617?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-208465/129001617.cms?width=150&height=112", "tag": "infrastructure"}]}
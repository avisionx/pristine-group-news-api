{"updated_at": {"date": {"d": "11", "m": "05", "Y": "2026"}, "time": {"H": "08", "M": "55", "S": "20"}}, "news": [{"title": "Court upholds Nagpur civic body's eviction drive on prime Subhash Road land", "para": "A district court has upheld the Nagpur Municipal Corporation's eviction of illegal occupants from a prime 15,000 sq m land parcel. The lease, granted in 1937 to Abhyankar Smarak Trust, expired in 1967 and was never renewed.", "href": "https://realty.economictimes.indiatimes.com/news/infrastructure/nagpur-court-rules-in-favor-of-civic-bodys-eviction-drive-on-prime-land/131007236?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-26418/131007236.cms?width=150&height=112", "tag": "infrastructure"}, {"title": "Dwarka projects to earn Delhi development body \u20b929,000 crore in licence fees", "para": "Delhi Development Authority is shifting to long-term land leasing, expecting over Rs 29,700 crore from three Dwarka projects over 55 years. A five-star hotel, a Transit Oriented Development, and a super-speciality hospital will generate substantial annual licence fees, boosting infrastructure and DDA's revenue streams.", "href": "https://realty.economictimes.indiatimes.com/news/industry/delhi-development-authority-set-to-earn-29700-crore-from-groundbreaking-dwarka-projects/131007301?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-73438/131007301.cms?width=150&height=112", "tag": "industry"}, {"title": "UP-RERA enables online complaints against excess transfer charges by promoters", "para": "The Uttar Pradesh Real Estate Regulatory Authority has made online complaint filing operational for allottees facing demands for transfer charges beyond the prescribed limits. Complaints can be filed through Form-M on the UP-RERA portal under the e-court mechanism, following the implementation of the 10th amendment to its General Regulations, 2019.", "href": "https://realty.economictimes.indiatimes.com/news/rera/up-rera-launches-online-complaints-for-excess-transfer-charges-on-property-transfers/131002956?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-65492/131002956.cms?width=150&height=112", "tag": "rera"}]}
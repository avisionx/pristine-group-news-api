{"updated_at": {"date": {"d": "24", "m": "05", "Y": "2026"}, "time": {"H": "11", "M": "05", "S": "15"}}, "news": [{"title": "Drain-top buildings to face higher tax in Sambhajinagar; crackdown on direct sewage discharge", "para": "Chhatrapati Sambhajinagar municipal corporation will raise property taxes for buildings constructed over major drains. This move aims to tackle monsoon flooding and improve desilting operations. The civic body also ordered strict action against direct sewage discharge into stormwater drains. Enforcement drives will ensure properties connect to sewage treatment plants.", "href": "https://realty.economictimes.indiatimes.com/news/industry/sambhajinagar-to-enforce-higher-property-tax-on-drain-top-buildings-amid-sewage-crackdown/131290128?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-680157/131290128.cms?width=150&height=112", "tag": "industry"}, {"title": "Delhi to overhaul property registration system, modernise sub-registrar offices: CM", "para": "The Delhi government is preparing to completely overhaul the property registration system in the capital, aiming to make Sub-Registrar offices more modern, transparent and citizen-friendly, with a focus on eliminating delays, corruption and dependence on agents.", "href": "https://realty.economictimes.indiatimes.com/news/industry/delhi-government-revamps-property-registration-for-transparency-and-efficiency/131290075?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-40782/131290075.cms?width=150&height=112", "tag": "industry"}, {"title": "Lucknow development body to redevelop dilapidated complex in Indira Nagar at \u20b9110 crore", "para": "Lucknow Development Authority (LDA) is set to redevelop the 40-year-old Kailashkunj Commercial Complex into a 13-storey mixed-use high-rise. The project, estimated at Rs 110 crore, will feature commercial spaces on lower floors and 3BHK residential flats above. Allottees will receive 1.25 times their current area in the new modern complex.", "href": "https://realty.economictimes.indiatimes.com/news/residential/lucknow-development-body-to-redevelop-dilapidated-complex-in-indira-nagar-at-110-crore/131289967?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-119992/131289967.cms?width=150&height=112", "tag": "residential"}]}
orable.", "href": "https://realty.economictimes.indiatimes.com/news/commercial/flexible-workspace-stock-likely-to-grow-16-18-to-140-145-million-sq-ft-in-fy27-fy28-crisil/130824963?utm_source=newslisting&utm_medium=latestNews", "img": "data:image/png;base64, ", "img-src": "https://etimg.etb2bimg.com/thumb/img-size-175920/130824963.cms?width=150&height=112", "tag": "commercial"}]}